<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
  const _desc  = ((locals.pageDesc || site.description || '').replace(/<[^>]+>/g,'').replace(/\s+/g,' ').trim()).slice(0,155);
  const _title = locals.pageTitle ? pageTitle + ' · ' + site.title : site.title;
  const _url   = site.url + (locals.canonical || '');
  const _img   = locals.ogImage ? (String(locals.ogImage).startsWith('http') ? locals.ogImage : site.url + locals.ogImage) : null;
-%>
  <title><%= _title %></title>
  <meta name="google" content="notranslate">
  <meta name="description" content="<%= _desc %>">
  <meta property="og:type"        content="<%= locals.ogType || 'website' %>">
  <meta property="og:title"       content="<%= _title %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:url"         content="<%= _url %>">
  <meta property="og:site_name"   content="<%= site.title %>">
  <% if (_img) { %><meta property="og:image" content="<%= _img %>">
  <% } %><meta name="twitter:card"        content="<%= _img ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title"       content="<%= _title %>">
  <meta name="twitter:description" content="<%= _desc %>">
  <% if (_img) { %><meta name="twitter:image" content="<%= _img %>">
  <% } %><link rel="canonical" href="<%= _url %>">
  <link rel="alternate" type="application/rss+xml" title="<%= site.title %>" href="<%= site.url %>/feed/rss">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<%- encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><rect width="32" height="32" rx="7" fill="#b04a2f"/><text x="16" y="23.5" font-family="system-ui,sans-serif" font-size="19" font-weight="700" fill="white" text-anchor="middle">${site.title.charAt(0).toUpperCase()}</text></svg>`) %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=<%= cssVer %>">
  <link rel="stylesheet" href="/css/highlight.css?v=<%= cssVer %>">
  <link rel="stylesheet" href="/css/custom.css?v=<%= cssVer %>">
  <% if (site.gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= site.gaId %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','<%= site.gaId %>');</script>
  <% } %>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-title"><%= site.title %></a>
      <button class="nav-toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <nav id="siteNav">
        <% if (locals.navLoaded) { %>
          <% (locals.nav || []).forEach(function(item) { %><a href="<%= item.url %>"<%= item.newTab ? ' target="_blank" rel="noopener"' : '' %>><%= item.label %></a><% }) %>
        <% } else { %>
          <a href="<%= locals.postsPath || '/' %>">Posts</a>
          <% if (locals.pages) { pages.forEach(function(p) { %>
            <a href="/<%= p.slug %>"><%= p.title %></a>
          <% }) } %>
          <a href="/tags">Tags</a>
          <a href="/feed/rss">RSS</a>
        <% } %>
        <% if (locals.navExtra) { %>
          <% (locals.navExtra || []).forEach(function(item) { %><a href="<%= item.url %>"<%= item.newTab ? ' target="_blank" rel="noopener"' : '' %>><%= item.label %></a><% }) %>
        <% } %>
      </nav>
    </div>
  </header>
  <script>
  (function() {
    var header = document.querySelector('.site-header');
    var toggle = document.getElementById('navToggle');
    var nav    = document.getElementById('siteNav');

    // Hamburger open/close
    toggle.addEventListener('click', function() {
      var open = nav.classList.toggle('open');
      toggle.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', open);
    });

    // Close nav when a link is clicked
    nav.addEventListener('click', function(e) {
      if (e.target.tagName === 'A') {
        nav.classList.remove('open');
        toggle.classList.remove('open');
      }
    });

    // Close nav on outside click
    document.addEventListener('click', function(e) {
      if (!header.contains(e.target)) {
        nav.classList.remove('open');
        toggle.classList.remove('open');
      }
    });

    // Close nav if user scrolls (mobile UX)
    window.addEventListener('scroll', function() {
      nav.classList.remove('open');
      toggle.classList.remove('open');
    }, { passive: true });
  })();
  </script>

<main class="container">
