<%
  locals.pageTitle = post.title;
  locals.canonical = '/private/posts/' + post.slug;
-%>
<%- include('layout') %>

<article class="post">
  <header class="post-header">
    <div class="post-meta">
      <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
    </div>
    <h1><%= post.title %></h1>
    <% if (post.coverImage) { %>
      <img class="post-cover-full lb-img" src="<%= post.coverImage %>" alt="<%= post.title %>" style="cursor:zoom-in">
    <% } %>
  </header>

  <div class="post-body">
    <%- post.html %>
  </div>

  <footer class="post-footer">
    <a href="/private" class="back-link">« Private posts</a>
  </footer>
</article>

<%- include('layout-end') %>
