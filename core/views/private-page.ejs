<%
  locals.pageTitle = page.title;
  locals.canonical = '/private/' + page.slug;
-%>
<%- include('layout') %>

<article class="post">
  <header class="post-header">
    <h1><%= page.title %></h1>
  </header>

  <div class="post-body">
    <%- page.html %>
  </div>

  <footer class="post-footer">
    <a href="/private/pages" class="back-link">← Pages</a>
  </footer>
</article>

<%- include('layout-end') %>
