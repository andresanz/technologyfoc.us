<%
  locals.pageTitle = 'Private posts';
  locals.canonical = '/private/posts';
-%>
<%- include('layout') %>

<div class="page-header">
  <h1>Private posts</h1>
  <p style="font-size:.875rem;color:var(--muted)"><a href="/private/logout">Sign out</a></p>
</div>

<div class="post-list">
  <% if (posts.length === 0) { %>
    <p class="empty">No private posts yet.</p>
  <% } else { %>
    <% posts.forEach(function(post) { %>
      <article class="post-card">
        <% if (post.coverImage) { %>
          <a href="/private/posts/<%= post.slug %>" class="post-cover">
            <img src="<%= post.coverImage %>" alt="<%= post.title %>">
          </a>
        <% } %>
        <div class="post-card-body">
          <div class="post-meta">
            <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
          </div>
          <h2><a href="/private/posts/<%= post.slug %>"><%= post.title %></a></h2>
          <% var ex = post.excerpt || ''; var truncated = ex.length > 140 ? ex.slice(0, 137) + '…' : ex; %>
          <% if (truncated) { %><p class="excerpt"><%= truncated %></p><% } %>
          <a href="/private/posts/<%= post.slug %>" class="read-more">Read more ›</a>
        </div>
      </article>
    <% }) %>
  <% } %>
</div>

<%- include('layout-end') %>
