<%
  locals.pageTitle = 'Gratitude';
  locals.canonical = '/private/gratitude';
-%>
<%- include('layout') %>

<div class="page-header">
  <h1>Gratitude</h1>
  <p style="font-size:.875rem;color:var(--muted)"><a href="/private/logout">Sign out</a></p>
</div>

<% if (entries.length === 0) { %>
  <p class="empty">No entries yet.</p>
<% } else { %>
  <div class="post-list">
    <% entries.forEach(function(e) { %>
      <article style="padding:1.25rem 0;border-bottom:1px solid var(--border)">
        <div class="post-meta" style="margin-bottom:.5rem">
          <time><%= e.date %></time>
          <% if (e.prompt) { %><span style="color:var(--muted)"> · <%= e.prompt %></span><% } %>
        </div>
        <p style="white-space:pre-wrap;margin:0"><%= e.response %></p>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('layout-end') %>
