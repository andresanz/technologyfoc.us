<%
  locals.pageTitle    = page.slug === 'home' ? null : page.title;
  locals.canonical    = page.slug === 'home' ? '/' : '/' + page.slug;
  locals.adminEditUrl = (locals.adminUrl || '') + '/pages/edit/' + encodeURIComponent(page._filename || page.slug + '.md');
-%>
<%- include('layout') %>

<article class="post<%= page.slug === 'home' ? ' home-page' : '' %>">

  <div class="post-body">
    <%- page.html %>
  </div>

  <% if (page.slug !== 'home') { %>
  <footer class="post-footer">
    <a href="/pages" class="back-link">← Pages</a>
  </footer>
  <% } %>
</article>

<%- include('layout-end') %>
