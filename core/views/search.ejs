<%- include('layout') %>

<% if (query) { %>
  <h1 class="page-title">Search: "<%= query %>"</h1>
  <% if (results.length === 0) { %>
    <p class="search-empty">No posts found for "<%= query %>".</p>
  <% } else { %>
    <p class="search-count"><%= results.length %> result<%= results.length === 1 ? '' : 's' %></p>
    <div class="post-list">
      <% results.forEach(function(post) { %>
        <article class="post-card">
          <a href="/post/<%= post.slug %>" class="card-link" aria-label="<%= post.title %>"></a>
          <% if (post.coverImage) { %>
            <div class="post-cover">
              <img src="<%= post.coverImage %>" alt="<%= post.title %>">
              <div class="post-kicker">
                <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
                <% (post.tags||[]).forEach(function(t) { %><a href="/tag/<%= t %>" class="tag tag-link"><%= t %></a><% }) %>
              </div>
            </div>
          <% } %>
          <div class="post-card-body">
            <% if (!post.coverImage) { %>
              <div class="post-kicker">
                <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
                <% (post.tags||[]).forEach(function(t) { %><a href="/tag/<%= t %>" class="tag tag-link"><%= t %></a><% }) %>
              </div>
            <% } %>
            <h2><%= post.title %></h2>
            <% if (post.excerpt) { %><p class="post-excerpt"><%= post.excerpt %></p><% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
<% } else { %>
  <h1 class="page-title">Search</h1>
<% } %>

<form class="search-form" action="/search" method="get">
  <input type="search" name="q" value="<%= query %>" placeholder="Search posts…" autofocus autocomplete="off">
  <button type="submit">Search</button>
</form>

<%- include('layout-end') %>
