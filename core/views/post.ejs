<%
  locals.pageTitle = post.title;
  locals.pageDesc  = post.excerpt;
  locals.canonical = '/post/' + post.slug;
  locals.ogType    = 'article';
  locals.ogImage   = post.coverImage || null;
-%>
<%- include('layout') %>

<article class="post">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <div class="post-meta">
      <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
      <% post.tags.forEach(function(t) { %>
        <a href="/tag/<%= t %>" class="tag"><%= t %></a>
      <% }) %>
    </div>
    <% if (post.coverImage) { %>
      <img class="post-cover-full lb-img" src="<%= post.coverImage %>" alt="<%= post.title %>" style="cursor:zoom-in">
    <% } %>
  </header>

  <div class="post-body<%= post.coverImage ? ' has-cover' : '' %>">
    <%- post.html %>
  </div>

  <footer class="post-footer">
    <div class="post-nav">
      <a href="/posts" class="back-link">« All posts</a>
      <% if (locals.newer) { %>
        <a href="/post/<%= newer.slug %>" class="back-link" title="<%= newer.title %>">‹ Newer</a>
      <% } %>
      <% if (locals.older) { %>
        <a href="/post/<%= older.slug %>" class="back-link" title="<%= older.title %>">Older ›</a>
      <% } %>
    </div>
    <% if (post.tags.length) { %>
      <div class="post-tags">
        <% post.tags.forEach(function(t) { %>
          <a href="/tag/<%= t %>" class="tag"><%= t %></a>
        <% }) %>
      </div>
    <% } %>
  </footer>
</article>

<%- include('layout-end') %>
