<%
  pageTitle = 'Navigation · ' + site.title;
-%>
<%- include('partials/head') %>

<div class="page-header">
  <div>
    
    <h1>Navigation</h1>
  </div>
  <div class="header-actions">
    <a href="<%= site.url %>" target="_blank" class="btn">View site ↗</a>
    <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveNav()">Save nav</button>
  </div>
</div>
<%- include('partials/flash') %>

<section class="card">
  <h3 style="margin-bottom:.75rem">All pages nav</h3>
  <div id="navBody">
    <% navItems.forEach(function(item) { %>
    <div class="nav-item-wrap" draggable="true">
      <div class="nav-item-row">
        <span class="drag-handle" title="Drag to reorder">⠿</span>
        <input type="text" class="nav-label" value="<%= item.label %>" placeholder="Label">
        <input type="text" class="nav-url"   value="<%= item.url || '' %>" placeholder="/path or https://… (blank if dropdown)">
        <label title="Enabled"><input type="checkbox" class="nav-enabled" <%= item.enabled !== false ? 'checked' : '' %>> on</label>
        <label title="New tab"><input type="checkbox" class="nav-newtab" <%= item.newTab ? 'checked' : '' %>> ↗</label>
        <button type="button" class="btn btn-sm" onclick="toggleChildren(this)">▾ Sub</button>
        <button type="button" class="btn btn-sm btn-danger" onclick="removeNavItem(this)">✕</button>
      </div>
      <% if (item.children && item.children.length) { %>
      <div class="nav-children open">
        <% item.children.forEach(function(child) { %>
        <div class="nav-child-row">
          <span style="color:var(--muted);padding:0 .25rem">↳</span>
          <input type="text" class="child-label" value="<%= child.label %>" placeholder="Label">
          <input type="text" class="child-url"   value="<%= child.url %>"   placeholder="/path or https://…">
          <label><input type="checkbox" class="child-newtab" <%= child.newTab ? 'checked' : '' %>> ↗</label>
          <button type="button" class="btn btn-sm btn-danger" onclick="removeNavItem(this)">✕</button>
        </div>
        <% }) %>
        <button type="button" class="btn btn-sm" style="margin:.25rem 0 .25rem 1.5rem" onclick="addChild(this)">+ Add link</button>
      </div>
      <% } else { %>
      <div class="nav-children">
        <button type="button" class="btn btn-sm" style="margin:.25rem 0 .25rem 1.5rem" onclick="addChild(this)">+ Add link</button>
      </div>
      <% } %>
    </div>
    <% }) %>
  </div>
  <div style="margin-top:1rem">
    <button type="button" class="btn" onclick="addNavItem()">+ Add item</button>
  </div>
</section>


<section class="card" style="margin-top:1rem">
  <h3 style="margin-bottom:.25rem">Page-specific nav links</h3>
  <p style="font-size:.85rem;color:var(--muted);margin-bottom:.75rem">Extra links appended to the nav on specific pages only. Match is exact path (e.g. <code>/private/posts</code>).</p>
  <div id="pageNavRules">
    <% pageNavItems.forEach(function(rule, ri) { %>
    <div class="pnav-rule" data-ri="<%= ri %>">
      <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
        <input type="text" class="pnav-path" value="<%= rule.path %>" placeholder="/path" style="flex:1;font-family:var(--mono);font-size:.85rem">
        <button type="button" class="btn btn-sm btn-danger" onclick="removeRule(this)">✕ Remove rule</button>
      </div>
      <table class="nav-table" style="margin-bottom:.5rem">
        <thead><tr>
          <th>Label</th><th>URL</th>
          <th style="width:5rem;text-align:center">New tab</th>
          <th style="width:3rem"></th>
        </tr></thead>
        <tbody class="pnav-links">
          <% (rule.links || []).forEach(function(link) { %>
          <tr class="nav-row">
            <td><input type="text" class="nav-label" value="<%= link.label %>" placeholder="Label"></td>
            <td><input type="text" class="nav-url"   value="<%= link.url %>"   placeholder="/path or https://…"></td>
            <td style="text-align:center"><input type="checkbox" class="nav-newtab" <%= link.newTab ? 'checked' : '' %>></td>
            <td><button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✕</button></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <button type="button" class="btn btn-sm" onclick="addPageLink(this)">+ Add link</button>
      <hr style="margin:1rem 0;border-color:var(--border)">
    </div>
    <% }) %>
  </div>
  <button type="button" class="btn" onclick="addPageRule()">+ Add page rule</button>
</section>

<style>
.nav-item-wrap { border: 1px solid var(--border); border-radius: 6px; margin-bottom: .5rem; overflow: hidden; }
.nav-item-wrap.drag-over { border-color: var(--accent); }
.nav-item-row { display: flex; align-items: center; gap: .4rem; padding: .4rem .5rem; background: var(--surface); flex-wrap: wrap; }
.nav-item-row input[type=text] { flex: 1; min-width: 80px; }
.nav-item-row label { display: flex; align-items: center; gap: .2rem; font-size: .8rem; color: var(--muted); white-space: nowrap; }
.nav-children { display: none; flex-direction: column; padding: .25rem .5rem; background: var(--bg); border-top: 1px solid var(--border); }
.nav-children.open { display: flex; }
.nav-child-row { display: flex; align-items: center; gap: .4rem; padding: .25rem 0; border-bottom: 1px solid var(--border); }
.nav-child-row:last-of-type { border-bottom: none; }
.nav-child-row input[type=text] { flex: 1; min-width: 80px; }
.nav-child-row label { display: flex; align-items: center; gap: .2rem; font-size: .8rem; color: var(--muted); }
.drag-handle { cursor: grab; color: var(--muted); font-size: 1.1rem; user-select: none; flex-shrink: 0; }
/* page nav table */
.nav-table { width: 100%; border-collapse: collapse; }
.nav-table th { text-align: left; font-size: .8rem; color: var(--muted); padding: .4rem .5rem; border-bottom: 1px solid var(--border); }
.nav-table td { padding: .4rem .5rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
.nav-table input[type=text] { width: 100%; }
</style>

<script>
// ── Drag-to-reorder (top-level items) ────────────────────────────────────────
let dragSrc = null;
const navBody = document.getElementById('navBody');
navBody.addEventListener('dragstart', e => {
  dragSrc = e.target.closest('.nav-item-wrap');
  if (dragSrc) { dragSrc.style.opacity = '.4'; e.dataTransfer.effectAllowed = 'move'; }
});
navBody.addEventListener('dragend', () => {
  document.querySelectorAll('.nav-item-wrap').forEach(r => { r.style.opacity = ''; r.classList.remove('drag-over'); });
});
navBody.addEventListener('dragover', e => {
  e.preventDefault();
  const wrap = e.target.closest('.nav-item-wrap');
  if (wrap && wrap !== dragSrc) {
    document.querySelectorAll('.nav-item-wrap').forEach(r => r.classList.remove('drag-over'));
    wrap.classList.add('drag-over');
  }
});
navBody.addEventListener('drop', e => {
  e.preventDefault();
  const wrap = e.target.closest('.nav-item-wrap');
  if (wrap && wrap !== dragSrc) navBody.insertBefore(dragSrc, wrap);
  document.querySelectorAll('.nav-item-wrap').forEach(r => r.classList.remove('drag-over'));
});

// ── Add / remove items ───────────────────────────────────────────────────────
function addNavItem() {
  const wrap = document.createElement('div');
  wrap.className = 'nav-item-wrap';
  wrap.draggable = true;
  wrap.innerHTML = `
    <div class="nav-item-row">
      <span class="drag-handle">⠿</span>
      <input type="text" class="nav-label" placeholder="Label">
      <input type="text" class="nav-url" placeholder="/path or https://… (blank if dropdown)">
      <label><input type="checkbox" class="nav-enabled" checked> on</label>
      <label><input type="checkbox" class="nav-newtab"> ↗</label>
      <button type="button" class="btn btn-sm" onclick="toggleChildren(this)">▾ Sub</button>
      <button type="button" class="btn btn-sm btn-danger" onclick="removeNavItem(this)">✕</button>
    </div>
    <div class="nav-children">
      <button type="button" class="btn btn-sm" style="margin:.25rem 0 .25rem 1.5rem" onclick="addChild(this)">+ Add link</button>
    </div>`;
  navBody.appendChild(wrap);
}

function removeNavItem(btn) { btn.closest('.nav-item-wrap, .nav-child-row').remove(); }

function toggleChildren(btn) {
  const children = btn.closest('.nav-item-wrap').querySelector('.nav-children');
  children.classList.toggle('open');
}

function addChild(btn) {
  const children = btn.closest('.nav-children');
  const row = document.createElement('div');
  row.className = 'nav-child-row';
  row.innerHTML = `
    <span style="color:var(--muted);padding:0 .25rem">↳</span>
    <input type="text" class="child-label" placeholder="Label">
    <input type="text" class="child-url" placeholder="/path or https://…">
    <label><input type="checkbox" class="child-newtab"> ↗</label>
    <button type="button" class="btn btn-sm btn-danger" onclick="removeNavItem(this)">✕</button>`;
  children.insertBefore(row, btn);
}

// ── Serialize ────────────────────────────────────────────────────────────────
function serializeRows(containerId) {
  return [...document.getElementById(containerId).querySelectorAll('.nav-item-wrap')].map(wrap => {
    const children = [...wrap.querySelectorAll('.nav-child-row')].map(r => ({
      label:  r.querySelector('.child-label').value.trim(),
      url:    r.querySelector('.child-url').value.trim() || '/',
      newTab: r.querySelector('.child-newtab').checked,
    })).filter(c => c.label);
    const item = {
      label:   wrap.querySelector('.nav-label').value.trim(),
      url:     wrap.querySelector('.nav-url').value.trim() || null,
      enabled: wrap.querySelector('.nav-enabled').checked,
      newTab:  wrap.querySelector('.nav-newtab').checked,
    };
    if (children.length) item.children = children;
    if (!item.url) delete item.url;
    return item;
  }).filter(i => i.label);
}

// ── Page nav rules ────────────────────────────────────────────────────────────
function addPageRule() {
  const container = document.getElementById('pageNavRules');
  const div = document.createElement('div');
  div.className = 'pnav-rule';
  div.innerHTML = `
    <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem">
      <input type="text" class="pnav-path" value="" placeholder="/path" style="flex:1;font-family:var(--mono);font-size:.85rem">
      <button type="button" class="btn btn-sm btn-danger" onclick="removeRule(this)">✕ Remove rule</button>
    </div>
    <table class="nav-table" style="margin-bottom:.5rem">
      <thead><tr>
        <th>Label</th><th>URL</th>
        <th style="width:5rem;text-align:center">New tab</th>
        <th style="width:3rem"></th>
      </tr></thead>
      <tbody class="pnav-links"></tbody>
    </table>
    <button type="button" class="btn btn-sm" onclick="addPageLink(this)">+ Add link</button>
    <hr style="margin:1rem 0;border-color:var(--border)">`;
  container.appendChild(div);
}

function removeRule(btn) { btn.closest('.pnav-rule').remove(); }

function addPageLink(btn) {
  const tbody = btn.closest('.pnav-rule').querySelector('.pnav-links');
  const tr = document.createElement('tr');
  tr.className = 'nav-row';
  tr.innerHTML = `
    <td><input type="text" class="nav-label" value="" placeholder="Label"></td>
    <td><input type="text" class="nav-url"   value="" placeholder="/path or https://…"></td>
    <td style="text-align:center"><input type="checkbox" class="nav-newtab"></td>
    <td><button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✕</button></td>`;
  tbody.appendChild(tr);
}

function serializePageNav() {
  return [...document.querySelectorAll('.pnav-rule')].map(rule => ({
    path:  rule.querySelector('.pnav-path').value.trim(),
    links: [...rule.querySelectorAll('.pnav-links .nav-row')].map(row => ({
      label:  row.querySelector('.nav-label').value.trim(),
      url:    row.querySelector('.nav-url').value.trim() || '/',
      newTab: row.querySelector('.nav-newtab').checked,
    })).filter(l => l.label),
  })).filter(r => r.path);
}

// ── Save via fetch ────────────────────────────────────────────────────────────
async function saveNav() {
  const btn = document.getElementById('saveBtn');
  btn.disabled = true;
  btn.textContent = 'Saving…';
  try {
    const nav     = serializeRows('navBody');
    const pageNav = serializePageNav();
    const r = await fetch('/server/nav', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ nav, pageNav }),
    });
    if (r.redirected || r.url.includes('/login')) {
      window.location.href = '/login';
      return;
    }
    const data = await r.json();
    if (data.ok) {
      window.location.reload();
    } else {
      alert('Error: ' + (data.error || 'unknown'));
      btn.disabled = false;
      btn.textContent = 'Save nav';
    }
  } catch(e) {
    alert('Save failed: ' + e.message);
    btn.disabled = false;
    btn.textContent = 'Save nav';
  }
}
</script>

<%- include('partials/foot') %>
