<%
  pageTitle = 'Pages · ' + site.title;
-%>
<%- include('partials/head') %>
<div class="page-header">
  <div>
    <h1>Pages</h1>
  </div>
  <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
    <a href="/pages/new" class="btn btn-primary">+ Public page</a>
    <a href="/pages/new?dir=private-pages" class="btn">+ Private page</a>
  </div>
</div>
<%- include('partials/flash') %>

<div style="display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap">
  <a href="/pages?status=published&visibility=<%= visibility %>" class="btn<%= status === 'published' ? ' btn-primary' : '' %>">Published</a>
  <a href="/pages?status=drafts&visibility=<%= visibility %>"    class="btn<%= status === 'drafts'    ? ' btn-primary' : '' %>">Drafts</a>
  <span style="width:1px;background:var(--border);margin:0 .25rem"></span>
  <a href="/pages?status=<%= status %>&visibility=all"     class="btn<%= visibility === 'all'     ? ' btn-primary' : '' %>">All</a>
  <a href="/pages?status=<%= status %>&visibility=public"  class="btn<%= visibility === 'public'  ? ' btn-primary' : '' %>">Public</a>
  <a href="/pages?status=<%= status %>&visibility=private" class="btn<%= visibility === 'private' ? ' btn-primary' : '' %>">Private</a>
</div>

<% if (pages.length === 0) { %>
  <p class="empty">No <%= status === 'drafts' ? 'draft pages' : 'published pages' %> yet.<% if (status !== 'drafts') { %> <a href="/pages/new">Create one →</a><% } %></p>
<% } else { %>
  <table class="post-table">
    <thead>
      <tr>
        <th>Title</th>
        <th data-sort="visibility" style="cursor:pointer;user-select:none">Visibility <span class="sort-icon">↕</span></th>
        <th>Slug</th>
        <th>Order</th>
        <th>Nav</th>
        <th data-sort="status" style="cursor:pointer;user-select:none">Status <span class="sort-icon">↕</span></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% pages.forEach(function(p) { %>
        <% const dirParam = p.isPrivate ? '?dir=private-pages' : ''; %>
        <tr>
          <td>
            <a href="/pages/edit/<%= p.filename %><%= dirParam %>"><%= p.title %></a>
            <% if (p.excerpt) { %><div style="font-size:.78rem;color:var(--muted);margin-top:.2rem;"><%= p.excerpt.slice(0,120) %><%= p.excerpt.length > 120 ? '…' : '' %></div><% } %>
          </td>
          <td data-value="<%= p.isPrivate ? 'private' : 'public' %>">
            <% if (p.isPrivate) { %><span class="badge-private">Private</span><% } else { %><span class="badge-public">Public</span><% } %>
          </td>
          <td><code><%= p.isPrivate ? '/private/' : '/' %><%= p.slug %></code></td>
          <td><%= p.order || '—' %></td>
          <td><%= (!p.isPrivate && p.nav !== false) ? '✓' : '' %></td>
          <td data-value="<%= p.draft ? 'draft' : 'live' %>">
            <% if (p.draft) { %>
              <span class="badge-draft">Draft</span>
            <% } else { %>
              <span class="badge-live">Live</span>
            <% } %>
          </td>
          <td style="text-align:right">
            <div class="row-actions" style="justify-content:flex-end">
              <a href="/pages/edit/<%= p.filename %><%= dirParam %>" class="btn btn-sm">Edit</a>
              <a href="<%= site.url %><%= p.isPrivate ? '/private/' : '/' %><%= p.slug %>" target="_blank" class="btn btn-sm">View ↗</a>
              <form method="POST" action="/pages/delete/<%= p.filename %><%= dirParam %>"
                    onsubmit="return confirm('Delete <%= p.title.replace(/'/g, "\\'") %>?')">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('th[data-sort]').forEach(function(th) {
    th.dataset.asc = '1';
    th.style.cursor = 'pointer';
    th.addEventListener('click', function() {
      const asc   = th.dataset.asc === '1';
      const col   = th.cellIndex;
      const tbody = th.closest('table').querySelector('tbody');
      const rows  = Array.from(tbody.rows);
      rows.sort(function(a, b) {
        const av = (a.cells[col].getAttribute('data-value') || a.cells[col].textContent).trim();
        const bv = (b.cells[col].getAttribute('data-value') || b.cells[col].textContent).trim();
        return asc ? av.localeCompare(bv) : bv.localeCompare(av);
      });
      rows.forEach(function(r) { tbody.appendChild(r); });
      th.dataset.asc = asc ? '0' : '1';
      th.querySelector('.sort-icon').textContent = asc ? '↓' : '↑';
    });
  });
});
</script>

<%- include('partials/foot') %>
