<%
  pageTitle = 'Ports';
-%>
<%- include('partials/head') %>
<div class="page-header">
  <h1>Port Registry</h1>
</div>
<%- include('partials/flash') %>

<section class="card">
  <table class="ports-table">
    <thead>
      <tr>
        <th>Domain</th>
        <th>Port (.env)</th>
        <th>Nginx port</th>
        <th>Status</th>
        <th>Change port</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(function(row) { %>
      <tr class="<%= row.conflict ? 'row-conflict' : row.mismatch ? 'row-mismatch' : '' %>">
        <td>
          <a href="/sites/<%= row.domain %>"><%= row.domain %></a>
        </td>
        <td>
          <code><%= row.port %></code>
          <% if (row.conflict) { %>
            <span class="badge badge-danger" title="Another site uses this port">conflict</span>
          <% } %>
        </td>
        <td>
          <% if (row.nginxPort) { %>
            <code><%= row.nginxPort %></code>
            <% if (row.mismatch) { %>
              <span class="badge badge-danger" title=".env and nginx ports differ">mismatch</span>
            <% } else { %>
              <span class="badge badge-ok">ok</span>
            <% } %>
          <% } else { %>
            <span class="muted">—</span>
          <% } %>
        </td>
        <td><span class="status-badge status-<%= row.status %>"><%= row.status %></span></td>
        <td>
          <form method="POST" action="/ports/<%= row.domain %>"
                class="port-form"
                onsubmit="return confirm('Change port for <%= row.domain %>? The service will restart.')">
            <input type="number" name="port" value="<%= row.port %>"
                   min="1024" max="65535" required class="port-input">
            <button class="btn btn-sm">Save</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<style>
.ports-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
.ports-table th {
  text-align: left; padding: .5rem .75rem;
  font-size: .72rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: .05em; color: var(--muted);
  border-bottom: 2px solid var(--border);
}
.ports-table td { padding: .55rem .75rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
.ports-table tr:last-child td { border-bottom: none; }
.ports-table tr.row-conflict td { background: #fff1f2; }
.ports-table tr.row-mismatch td { background: #fffbeb; }

.badge {
  display: inline-block; font-size: .68rem; font-weight: 600;
  padding: .1em .45em; border-radius: 4px; margin-left: .35rem;
  vertical-align: middle;
}
.badge-danger { background: #fee2e2; color: #991b1b; }
.badge-ok     { background: #dcfce7; color: #15803d; }

.port-form { display: flex; gap: .4rem; align-items: center; }
.port-input {
  width: 5.5rem; padding: .25rem .4rem; border-radius: 5px;
  border: 1px solid var(--border); font-size: .85rem;
  background: var(--surface); color: var(--text);
}
</style>

<%- include('partials/foot') %>
