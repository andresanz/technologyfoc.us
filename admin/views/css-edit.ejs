<%
  pageTitle = 'Custom CSS · ' + site.title;
-%>
<%- include('partials/head') %>

<div class="page-header">
  <div>
    
    <h1>Custom CSS <span class="muted">— <%= site.title %></span></h1>
  </div>
  <div class="header-actions">
    <a href="<%= site.url %>" target="_blank" class="btn">View site ↗</a>
    <button type="button" id="fmtBtn" class="btn">Format</button>
    <button form="css-form" type="submit" class="btn btn-primary">Save CSS</button>
  </div>
</div>
<%- include('partials/flash') %>

<form id="css-form" method="POST" action="/server/css">
  <section class="card" style="padding:0; overflow:hidden">
    <textarea name="css" id="cssEditor" spellcheck="false"><%= css %></textarea>
  </section>
</form>

<style>
#cssEditor {
  display: block;
  width: 100%;
  min-height: 70vh;
  padding: 1rem 1.25rem;
  font-family: 'Fira Code', 'Cascadia Code', 'Menlo', monospace;
  font-size: .85rem;
  line-height: 1.6;
  border: none;
  outline: none;
  resize: vertical;
  background: #fff;
  color: #1a1a1a;
  tab-size: 2;
  box-sizing: border-box;
}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/js-beautify/1.15.1/beautify-css.min.js"></script>
<script>
// Tab key inserts spaces instead of jumping focus
document.getElementById('cssEditor').addEventListener('keydown', function(e) {
  if (e.key === 'Tab') {
    e.preventDefault();
    const s = this.selectionStart, end = this.selectionEnd;
    this.value = this.value.slice(0, s) + '  ' + this.value.slice(end);
    this.selectionStart = this.selectionEnd = s + 2;
  }
});

document.getElementById('fmtBtn').addEventListener('click', function() {
  const el = document.getElementById('cssEditor');
  if (typeof css_beautify === 'function') {
    el.value = css_beautify(el.value, {
      indent_size: 2,
      selector_separator_newline: true,
      end_with_newline: true,
    });
  }
});
</script>

<%- include('partials/foot') %>
