<%
  pageTitle = 'Backups · Server';
  function pillClass(daysSince) {
    if (daysSince == null) return 'pill-muted';
    if (daysSince > 7) return 'pill-fail';
    if (daysSince > 2) return 'pill-warn';
    return 'pill-ok';
  }
  function ago(date) {
    if (!date) return '—';
    const d = (Date.now() - new Date(date)) / 86400000;
    if (d < 1)  return Math.round(d * 24) + 'h ago';
    if (d < 30) return Math.round(d) + 'd ago';
    return Math.round(d / 30) + 'mo ago';
  }
-%>
<%- include('partials/head') %>

<style>
.bk-section { margin-bottom: 2rem; }
.bk-head {
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; margin-bottom: .6rem; flex-wrap: wrap;
}
.bk-head h2 {
  font-size: 1.15rem; font-weight: 600; margin: 0;
  display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
}
.bk-meta { font-size: .82rem; color: var(--muted); font-weight: 400; }
.bk-actions { display: flex; gap: .4rem; }

.pill {
  display: inline-flex; align-items: center; gap: .35rem;
  font-size: .78rem; font-weight: 600; padding: .2em .7em;
  border-radius: 999px; line-height: 1.5;
}
.pill::before { content:''; display:inline-block; width:6px; height:6px; border-radius:50%; }
.pill-ok    { background:#dcfce7; color:#15803d; } .pill-ok::before    { background:#16a34a; }
.pill-warn  { background:#fef9c3; color:#92400e; } .pill-warn::before  { background:#d97706; }
.pill-fail  { background:#fee2e2; color:#991b1b; } .pill-fail::before  { background:#dc2626; }
.pill-muted { background:var(--border); color:var(--muted); } .pill-muted::before { background:var(--muted); }

.bk-table { width: 100%; border-collapse: collapse; font-size: .95rem; }
.bk-table th {
  text-align: left; padding: .55rem .85rem; color: var(--muted);
  font-weight: 600; font-size: .76rem; text-transform: uppercase;
  letter-spacing: .05em; border-bottom: 1px solid var(--border);
}
.bk-table td { padding: .65rem .85rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
.bk-table tr:last-child td { border-bottom: none; }
.bk-table tr:hover td { background: var(--surface-2); }
.bk-table .key { font-family: var(--mono); font-size: .88rem; word-break: break-all; }
.bk-table .num { color: var(--muted); white-space: nowrap; }
.bk-empty { padding: 1.75rem 1rem; color: var(--muted); font-size: .95rem; text-align: center; }

.log-box {
  background: #0d1117; color: #c9d1d9; border-radius: var(--radius);
  padding: .8rem 1rem; font-family: var(--mono); font-size: .72rem;
  line-height: 1.6; max-height: 280px; overflow-y: auto;
  white-space: pre-wrap; word-break: break-all;
  margin-top: .6rem; display: none;
}
.spinner-inline {
  display: inline-block; width: 12px; height: 12px;
  border: 2px solid rgba(0,0,0,.15); border-top-color: var(--accent);
  border-radius: 50%; animation: spin .7s linear infinite;
  vertical-align: middle; margin-right: .35rem;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="page-header">
  <h1>Backups</h1>
</div>

<%- include('partials/flash') %>

<% if (running) { %>
<div class="alert alert-info" style="margin-bottom:1rem">
  <span class="spinner-inline"></span> Backup running — page will refresh when done…
</div>
<% } %>

<%/* ── 0. Platform backup (new — andresanz-com/backups/platform/) ──────── */%>
<% const latestPlat = platformBackups && platformBackups[0]; %>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Platform
      <% if (latestPlat) { %><span class="pill pill-ok">latest <%= latestPlat.date %></span><% } else { %><span class="pill pill-muted">none</span><% } %>
      <span class="bk-meta">andresanz-com/backups/platform · <%= platformBackups.length %> snapshot<%= platformBackups.length !== 1 ? 's' : '' %> · daily 3am · monthly restore drill</span>
    </h2>
    <div style="display:flex;gap:.5rem">
      <form method="POST" action="/server/backups/platform/run" style="display:inline">
        <button class="btn btn-sm">⏵ Run now</button>
      </form>
      <form method="POST" action="/server/backups/platform/drill" style="display:inline" title="Download latest backup, extract, verify DB + content integrity. Telegrams result.">
        <button class="btn btn-sm">⟳ Test restore</button>
      </form>
    </div>
  </div>
  <% if (platformBackups.length) { %>
    <table class="bk-table">
      <thead><tr><th>Date</th><th>Size</th><th></th></tr></thead>
      <tbody>
        <% platformBackups.slice(0, 10).forEach(p => { %>
          <tr>
            <td><code><%= p.date %></code></td>
            <td><%= p.size %></td>
            <td style="text-align:right">
              <a href="/server/backups/download?key=<%= encodeURIComponent(p.key) %>&bucket=andresanz-com" class="btn btn-sm">↓</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="bk-empty">No platform backups yet — run one now or wait for tonight at 3am.</p>
  <% } %>
</section>

<%/* ── 1. Full server backups ─────────────────────────────────────────── */%>
<% const latestSrv = backups[0]; const srvAgo = latestSrv ? ago(latestSrv.modified) : null; %>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Server config
      <% if (backups.length) { %><span class="pill pill-ok">last <%= ago(backups[0].modified) %></span><% } else { %><span class="pill pill-muted">never</span><% } %>
      <span class="bk-meta"><%= bucket %>/server-config · <%= backups.length %> archive<%= backups.length !== 1 ? 's' : '' %> · keeps 30 · daily 2am</span>
    </h2>
    <div class="bk-actions">
      <button class="btn btn-sm" onclick="toggleLog('logBox','/server/backups/log')">Log</button>
      <form method="POST" action="/server/backups/run" onsubmit="startBackup()" style="display:inline">
        <button class="btn btn-sm btn-primary" id="backupBtn">
          <% if (running) { %><span class="spinner-inline"></span>Running…<% } else { %>Back up now<% } %>
        </button>
      </form>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <% if (backups.length === 0) { %>
      <div class="bk-empty">No backups yet.</div>
    <% } else { %>
    <table class="bk-table">
      <thead><tr><th>When</th><th>Size</th><th>File</th><th></th></tr></thead>
      <tbody>
        <% backups.slice(0, 10).forEach(b => { %>
        <tr>
          <td class="num"><%= b.modified %></td>
          <td class="num"><%= b.mb %> MB</td>
          <td class="key"><a href="/server/backups/download?key=<%= encodeURIComponent(b.key) %>"><%= b.name %></a></td>
          <td style="text-align:right">
            <form method="POST" action="/server/backups/delete" style="display:inline"
                  onsubmit="return confirm('Delete this backup?')">
              <input type="hidden" name="key" value="<%= b.key %>">
              <button class="btn btn-sm btn-danger">✕</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
  <div class="log-box" id="logBox">Loading…</div>
</section>

<%/* ── 2. Content backups ─────────────────────────────────────────────── */%>
<% const latestCnt = contentBackups && contentBackups[0]; const cntAgo = latestCnt ? ago(latestCnt.modified) : null; %>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Content
      <% if (latestCnt) { %><span class="pill pill-ok">last <%= cntAgo %></span><% } else { %><span class="pill pill-muted">never</span><% } %>
      <span class="bk-meta">sanz-backups/server-content · <%= (contentBackups||[]).length %> archive<%= (contentBackups||[]).length !== 1 ? 's' : '' %> · keeps 60 · every 6h</span>
    </h2>
    <div class="bk-actions">
      <form method="POST" action="/server/backups/content/run" style="display:inline">
        <button class="btn btn-sm btn-primary">Back up content now</button>
      </form>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <% if (!contentBackups || contentBackups.length === 0) { %>
      <div class="bk-empty">No content backups yet.</div>
    <% } else { %>
    <table class="bk-table">
      <thead><tr><th>When</th><th>Size</th><th>File</th><th></th></tr></thead>
      <tbody>
        <% contentBackups.slice(0, 10).forEach(b => { %>
        <tr>
          <td class="num"><%= b.modified %></td>
          <td class="num"><%= b.kb %> KB</td>
          <td class="key"><a href="/server/backups/download?key=<%= encodeURIComponent(b.key) %>"><%= b.name %></a></td>
          <td style="text-align:right">
            <form method="POST" action="/server/backups/delete" style="display:inline"
                  onsubmit="return confirm('Delete this backup?')">
              <input type="hidden" name="key" value="<%= b.key %>">
              <button class="btn btn-sm btn-danger">✕</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</section>

<%/* ── 3. Volume backups ──────────────────────────────────────────────── */%>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Volume
      <span class="bk-meta">/mnt/volume01 · <%= (localBackups||[]).length %> day<%= (localBackups||[]).length !== 1 ? 's' : '' %></span>
    </h2>
    <div class="bk-actions">
      <button class="btn btn-sm" onclick="toggleLog('localLogBox','/server/backups/log?src=local')">Log</button>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <% if (!localBackups || localBackups.length === 0) { %>
      <div class="bk-empty">No volume backups yet.</div>
    <% } else { %>
    <table class="bk-table">
      <thead><tr><th>Date</th><th>Files</th><th>Size</th></tr></thead>
      <tbody>
        <% localBackups.slice(0, 10).forEach(b => { %>
        <tr>
          <td><a href="/server/backups/local/<%= b.date %>"><%= b.date.replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3') %></a></td>
          <td class="num"><%= b.files %></td>
          <td class="num"><%= b.mb %> MB</td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
  <div class="log-box" id="localLogBox">Loading…</div>
</section>

<%/* ── 4. Mac backups ─────────────────────────────────────────────────── */%>
<%
  const latestMac = macBackups && macBackups[0];
  const macDaysSince = latestMac ? Math.floor((Date.now() - new Date(latestMac.modified)) / 86400000) : null;
%>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Mac
      <span class="pill <%= pillClass(macDaysSince) %>">
        <%= latestMac ? ago(latestMac.modified) : 'never' %>
      </span>
      <span class="bk-meta">sanz-backups/mac (+ legacy) · <%= (macBackups||[]).length %> snapshot<%= (macBackups||[]).length !== 1 ? 's' : '' %> · daily 2am</span>
    </h2>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <% if (!macBackups || macBackups.length === 0) { %>
      <div class="bk-empty">No Mac backups found in S3.</div>
    <% } else { %>
    <table class="bk-table">
      <thead><tr><th>Snapshot</th><th>When</th><th></th></tr></thead>
      <tbody>
        <% macBackups.slice(0, 10).forEach(b => { %>
        <tr>
          <td class="key">
            <a href="/mac/snapshot/<%= encodeURIComponent(b.name) %>"><%= b.name %></a>
            <% if (b.source === 'legacy') { %><span class="pill pill-warn" style="margin-left:.5rem;font-size:.65rem;padding:.05em .5em">legacy</span><% } %>
          </td>
          <td class="num"><%= b.modified %></td>
          <td style="text-align:right">
            <form method="POST" action="/server/backups/mac/delete" style="display:inline"
                  onsubmit="return confirm('Delete <%= b.name %>?')">
              <input type="hidden" name="key" value="<%= b.key %>">
              <input type="hidden" name="bucket" value="<%= b.bucket %>">
              <button class="btn btn-sm btn-danger">✕</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</section>

<%/* ── 5. Michele (Windows) — placeholder ──────────────────────────── */%>
<section class="bk-section">
  <div class="bk-head">
    <h2>
      Michele
      <span class="pill pill-muted">not configured</span>
      <span class="bk-meta">sanz-backups/michele · restic via Windows Task Scheduler (TBD)</span>
    </h2>
  </div>
  <div class="card" style="padding:0;overflow:hidden">
    <div class="bk-empty">Set up restic on Michele's laptop pointing to s3://sanz-backups/michele/.</div>
  </div>
</section>

<script>
const LAST_STATUS = <%- JSON.stringify(last || null) %>;
let pollInterval = null;

function startPolling() {
  if (pollInterval) return;
  const btn = document.getElementById('backupBtn');
  if (btn) { btn.innerHTML = '<span class="spinner-inline"></span>Running…'; btn.disabled = true; }
  pollInterval = setInterval(async () => {
    try {
      const r = await fetch('/server/backups/status');
      const d = await r.json();
      if (!d.running && d.last !== LAST_STATUS) {
        clearInterval(pollInterval);
        window.location.reload();
      }
    } catch {}
  }, 2000);
}

<% if (running) { %>startPolling();<% } %>
function startBackup() { setTimeout(startPolling, 500); }

async function toggleLog(boxId, url) {
  const box = document.getElementById(boxId);
  if (box.style.display === 'block') { box.style.display = 'none'; return; }
  box.style.display = 'block';
  box.textContent = 'Loading…';
  try {
    const r = await fetch(url);
    if (!r.ok) { box.textContent = 'Error: ' + r.status + ' ' + r.statusText; return; }
    const d = await r.json();
    box.textContent = d.log || '(log is empty)';
    box.scrollTop = box.scrollHeight;
  } catch (e) { box.textContent = 'Failed to load log: ' + e.message; }
}
</script>

<%- include('partials/foot') %>
