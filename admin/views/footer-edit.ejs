<%
  pageTitle = 'Footer · ' + site.title;
-%>
<%- include('partials/head') %>
<link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">

<div class="page-header">
  <div>
    <h1>Footer</h1>
    <p style="font-size:.85rem;color:var(--muted);margin-top:.25rem">Markdown or HTML — rendered at the bottom of every page.</p>
  </div>
  <div class="header-actions">
    <a href="<%= site.url %>" target="_blank" class="btn">View site ↗</a>
    <button form="footer-form" type="submit" class="btn btn-primary">Save footer</button>
  </div>
</div>
<%- include('partials/flash') %>

<form id="footer-form" method="POST" action="/pages/footer">
  <div class="edit-layout">
    <div class="edit-main">
      <textarea name="body" id="editor"><%= body %></textarea>
    </div>

    <aside class="edit-sidebar">
      <section class="card">
        <h3>Tips</h3>
        <p style="font-size:.85rem;color:var(--muted);line-height:1.5">
          Anything here renders inside the site footer on every page.
        </p>
        <ul style="font-size:.82rem;color:var(--muted);line-height:1.6;padding-left:1rem;margin-top:.5rem">
          <li>Markdown or raw HTML both work</li>
          <li>Keep it short — one or two lines</li>
          <li>Use <code>[text](url)</code> for links</li>
          <li>Changes are cached — may take a moment to appear</li>
        </ul>
      </section>
    </aside>
  </div>
</form>

<%- include('partials/md-help') %>

<script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>
<script>
const mdHelp        = document.getElementById('mdHelp');
const mdHelpOverlay = document.getElementById('mdHelpOverlay');
function openMdHelp()  { mdHelp.style.right = '0'; mdHelpOverlay.style.display = 'block'; }
function closeMdHelp() { mdHelp.style.right = '-420px'; mdHelpOverlay.style.display = 'none'; }
document.getElementById('closeMdHelp').addEventListener('click', closeMdHelp);
mdHelpOverlay.addEventListener('click', closeMdHelp);
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMdHelp(); });

const isMobile = window.innerWidth < 768;
const easyMDE = new EasyMDE({
  element:      document.getElementById('editor'),
  spellChecker: false,
  autosave:     { enabled: false },
  minHeight:    '200px',
  toolbar: isMobile
    ? ['bold','italic','|','unordered-list','ordered-list','|','link','|','preview',
       { name:'help', action: openMdHelp, className:'fa fa-question-circle', title:'Markdown help' }]
    : ['bold','italic','heading','|','quote','unordered-list','ordered-list','|',
       'link','image','|','preview','side-by-side','fullscreen','|',
       { name:'help', action: openMdHelp, className:'fa fa-question-circle', title:'Markdown help' }],
});

document.getElementById('footer-form').addEventListener('submit', () => {
  easyMDE.codemirror.save();
});
</script>

<%- include('partials/foot') %>
