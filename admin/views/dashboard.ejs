<%
  pageTitle = 'Dashboard';
-%>
<%- include('partials/head') %>
<div class="page-header">
  <h1>Dashboard</h1>
</div>
<%- include('partials/flash') %>

<div class="two-col">
  <div>
    <section class="card">
      <h2>andresanz.com <span class="status-badge status-<%= typeof site !== 'undefined' ? site.status : 'unknown' %>"><%= typeof site !== 'undefined' ? site.status : 'unknown' %></span></h2>
      <% if (typeof site !== 'undefined' && site) { %>
      <dl class="config-list">
        <dt>URL</dt>       <dd><a href="<%= site.url %>" target="_blank"><%= site.url %></a></dd>
        <dt>Posts</dt>     <dd><%= site.postCount %></dd>
        <dt>Pages</dt>     <dd><%= site.pageCount %></dd>
        <dt>Port</dt>      <dd><%= site.port %></dd>
      </dl>
      <% } %>
    </section>

    <section class="card">
      <h2>Quick links</h2>
      <div class="btn-row" style="flex-wrap:wrap;gap:.5rem">
        <a href="/posts" class="btn btn-primary">Posts</a>
        <a href="/pages" class="btn">Pages</a>
        <a href="/media" class="btn">Media</a>
        <a href="/redirects" class="btn">Redirects</a>
        <a href="/server" class="btn">Server</a>
        <a href="/logs" class="btn">Logs</a>
      </div>
    </section>
  </div>

  <section class="card">
    <h2>Service</h2>
    <div class="btn-row" style="margin-bottom:1rem">
      <form method="POST" action="/sites/restart">
        <button class="btn">Restart</button>
      </form>
      <button class="btn" id="bustBtn">Bust cache</button>
    </div>
    <a href="/sites" class="btn btn-sm">Site details →</a>
  </section>
</div>

<script>
document.getElementById('bustBtn').addEventListener('click', async function() {
  this.disabled = true;
  this.textContent = 'Busting…';
  const r = await fetch('/sites/bust-cache', { method: 'POST' });
  this.textContent = r.ok ? 'Cache cleared ✓' : 'Failed ✗';
  setTimeout(() => { this.textContent = 'Bust cache'; this.disabled = false; }, 2000);
});
</script>

<%- include('partials/foot') %>
