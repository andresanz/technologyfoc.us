<%
  pageTitle = (r.domain ? 'Edit Redirect' : 'New Redirect');
-%>
<%- include('partials/head') %>
<div class="page-header">
  <div>
    <a href="/redirects" class="back-link">← Redirects</a>
    <h1><%= r.domain ? 'Edit: ' + r.domain : 'New Redirect' %></h1>
  </div>
</div>
<%- include('partials/flash') %>

<div class="card" style="max-width:520px">
  <form method="POST" action="<%= action %>">
    <fieldset>
      <legend>Redirect</legend>

      <% if (!r.domain) { %>
      Domain <span class="required">*</span>
      <label>
        <input type="text" name="domain" placeholder="example.com" value="" required autocomplete="off">
        <span class="hint">No https:// — www. is handled automatically.</span>
      </label>
      <% } %>

      Destination URL <span class="required">*</span>
      <label>
        <input type="text" name="to" placeholder="https://target.com" value="<%= r.to || '' %>" required autocomplete="off">
      </label>

      Redirect type
      <label>
        <select name="code">
          <option value="301" <%= (r.code || 301) == 301 ? 'selected' : '' %>>301 — Permanent</option>
          <option value="302" <%= r.code == 302 ? 'selected' : '' %>>302 — Temporary</option>
        </select>
        <span class="hint">Use 301 for final destinations. Use 302 while testing.</span>
      </label>

      Note
      <label>
        <input type="text" name="note" placeholder="Why this redirect exists" value="<%= r.note || '' %>">
      </label>

      <label class="checkbox-label">
        <input type="checkbox" name="preservePath" <%= r.preservePath ? 'checked' : '' %>>
        Preserve path &amp; query string
      </label>
      <span class="hint" style="display:block;margin-top:.25rem;margin-bottom:.5rem;">
        e.g. example.com<strong>/foo?x=1</strong> → destination.com<strong>/foo?x=1</strong>
      </span>

    </fieldset>

    <div class="form-footer">
      <button type="submit" class="btn btn-primary">Save redirect</button>
      <a href="/redirects" class="btn">Cancel</a>
    </div>
  </form>
</div>
<%- include('partials/foot') %>
