<%
  pageTitle = 'Edit Prompt';
-%>
<%- include('partials/head') %>

<div class="page-header">
  <div>
    <a href="/gratitude-prompts#prompts" class="back-link">← Prompts</a>
    <h1>Edit Prompt</h1>
  </div>
</div>
<%- include('partials/flash') %>

<section class="card">
  <form method="POST" action="/gratitude-prompts/edit/<%= idx %>">
    <textarea name="text" rows="4" required style="width:100%;box-sizing:border-box;margin-bottom:1rem"><%= text %></textarea>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
</section>

<%- include('partials/foot') %>
