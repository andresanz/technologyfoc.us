<%
  pageTitle = 'Redirects';
-%>
<%- include('partials/head') %>
<div class="page-header">
  <div>
    <h1>Redirects</h1>
    <span style="font-size:.8rem;color:var(--muted);">Hits last
      <a href="?days=7"  style="color:<%= days==7  ? 'var(--text)' : 'var(--accent)' %>;">7d</a> ·
      <a href="?days=30" style="color:<%= days==30 ? 'var(--text)' : 'var(--accent)' %>;">30d</a> ·
      <a href="?days=90" style="color:<%= days==90 ? 'var(--text)' : 'var(--accent)' %>;">90d</a>
    </span>
  </div>
  <a href="/redirects/new" class="btn btn-primary">+ New redirect</a>
</div>
<%- include('partials/flash') %>

<% if (redirects.length === 0) { %>
  <div class="card" style="text-align:center;padding:3rem 1.5rem;">
    <p style="color:var(--muted);margin-bottom:1rem;">No redirects configured yet.</p>
    <a href="/redirects/new" class="btn btn-primary">+ Add your first redirect</a>
  </div>
<% } else { %>
<div class="card" style="padding:0;overflow:hidden;">
  <table class="post-table" style="margin:0;">
    <thead>
      <tr>
        <th data-col="0" class="sortable">Domain</th>
        <th data-col="1" class="sortable">Destination</th>
        <th data-col="2" class="sortable">Code</th>
        <th data-col="3" class="sortable">Hits</th>
        <th data-col="4" class="sortable">SSL</th>
        <th data-col="5" class="sortable">Updated</th>
        <th>Note</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% redirects.forEach(function(r) { %>
      <tr>
        <td data-label="Domain"><code style="font-size:.8rem;"><%= r.domain %></code></td>
        <td data-label="Destination">
          <a href="<%= r.to %>" target="_blank" rel="noopener"
             style="font-size:.85rem;max-width:280px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;vertical-align:bottom;">
            <%= r.to %>
          </a>
          <% if (r.preservePath) { %>
            <span class="tag" style="margin-left:.35rem;">+path</span>
          <% } %>
        </td>
        <td data-label="Code">
          <span class="status-badge <%= r.code == 302 ? 'status-inactive' : 'status-active' %>">
            <%= r.code || 301 %>
          </span>
        </td>
        <td data-label="Hits" style="font-size:.85rem;font-weight:600;">
          <%= stats[r.domain] ? stats[r.domain].toLocaleString() : '—' %>
          <% var cx = countryStats && countryStats[r.domain]; %>
          <% if (cx && cx.length) { %>
            <div style="margin-top:.3rem;display:flex;flex-wrap:wrap;gap:.2rem;">
              <% cx.slice(0,5).forEach(function(c) {
                   var flag = c.country ? String.fromCodePoint(...[...c.country.toUpperCase()].map(ch => 0x1F1E6 - 65 + ch.charCodeAt(0))) : '🌐';
              %>
                <span title="<%= c.country %>: <%= c.hits %>" style="font-size:.75rem;white-space:nowrap;cursor:default;"><%= flag %></span>
              <% }) %>
            </div>
          <% } %>
        </td>
        <td data-label="SSL">
          <% var sslInfo = ssl[r.domain]; %>
          <% if (sslInfo) { %>
            <span class="status-badge status-<%= sslInfo.status === 'ok' ? 'active' : sslInfo.status === 'warning' ? '' : 'failed' %>"
                  title="Expires <%= sslInfo.expires %>">
              <%= sslInfo.daysLeft %>d
            </span>
          <% } else { %>
            <form method="POST" action="/redirects/<%= r.domain %>/ssl" style="display:inline">
              <button class="btn btn-sm">Get SSL</button>
            </form>
          <% } %>
        </td>
        <td data-label="Updated" style="color:var(--muted);font-size:.8rem;white-space:nowrap;">
          <% if (r.updatedAt) { %>
            <% var d = new Date(r.updatedAt); %>
            <span title="<%= d.toLocaleString() %>"><%= d.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></span>
          <% } else { %>—<% } %>
        </td>
        <td data-label="Note" style="color:var(--muted);font-size:.82rem;"><%= r.note || '—' %></td>
        <td class="row-actions">
          <a href="/redirects/<%= r.domain %>/edit" class="btn btn-sm">Edit</a>
          <form method="POST" action="/redirects/<%= r.domain %>/delete" style="display:inline"
                onsubmit="return confirm('Delete redirect for <%= r.domain %>?')">
            <button class="btn btn-sm btn-danger">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
<style>
th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
th.sortable::after { content: ' ⇅'; opacity: .35; font-size: .75em; }
th.sort-asc::after  { content: ' ↑'; opacity: 1; }
th.sort-desc::after { content: ' ↓'; opacity: 1; }
</style>
<script>
(function () {
  const ths = document.querySelectorAll('th.sortable');
  ths.forEach(th => th.addEventListener('click', () => {
    const col  = +th.dataset.col;
    const asc  = !th.classList.contains('sort-asc');
    ths.forEach(t => t.classList.remove('sort-asc', 'sort-desc'));
    th.classList.add(asc ? 'sort-asc' : 'sort-desc');

    const tbody = th.closest('table').querySelector('tbody');
    const rows  = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
      const av = cellVal(a, col);
      const bv = cellVal(b, col);
      return asc ? av.localeCompare(bv, undefined, { numeric: true })
                 : bv.localeCompare(av, undefined, { numeric: true });
    });
    rows.forEach(r => tbody.appendChild(r));
  }));

  function cellVal(row, col) {
    const td = row.querySelectorAll('td')[col];
    if (!td) return '';
    return td.textContent.trim().replace(/[^0-9a-z.]/gi, ' ').trim().toLowerCase();
  }
})();
</script>
<%- include('partials/foot') %>
