<%
  pageTitle = 'Volume · Server';
  function fmtDate(d) { return d ? new Date(d).toLocaleString() : '—'; }
-%>
<%- include('partials/head') %>

<style>
.info-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.75rem;margin-bottom:1.5rem; }
.info-card { background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem; }
.info-label { font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:.35rem; }
.info-value { font-size:1.3rem;font-weight:700; }
.info-sub   { font-size:.78rem;color:var(--muted);margin-top:.2rem; }
.bar-track { height:4px;background:var(--border);border-radius:2px;margin-top:.5rem;overflow:hidden; }
.bar-fill  { height:100%;border-radius:2px;background:var(--accent); }
.bar-fill.warn   { background:var(--warning); }
.bar-fill.danger { background:var(--danger);  }
.bk-table { width:100%;border-collapse:collapse;font-size:.875rem; }
.bk-table th { text-align:left;padding:.5rem .75rem;color:var(--muted);font-weight:500;border-bottom:1px solid var(--border); }
.bk-table td { padding:.55rem .75rem;border-bottom:1px solid var(--border); }
</style>

<div class="page-header">
  <div>
    
    <h1>Volume: <%= linodeVolume ? linodeVolume.label : 'volume01' %></h1>
  </div>
</div>

<%- include('partials/flash') %>

<!-- Linode info -->
<% if (linodeVolume) { %>
<div class="info-grid">
  <div class="info-card">
    <div class="info-label">Status</div>
    <div class="info-value" style="font-size:1rem"><%= linodeVolume.status %></div>
    <div class="info-sub"><%= linodeVolume.region %></div>
  </div>
  <div class="info-card">
    <div class="info-label">Provisioned</div>
    <div class="info-value"><%= linodeVolume.size %> GB</div>
    <div class="info-sub">block storage</div>
  </div>
  <% if (disk) { %>
  <div class="info-card">
    <div class="info-label">Used</div>
    <div class="info-value"><%= kb(disk.used) %></div>
    <div class="info-sub">of <%= kb(disk.size) %> · <%= disk.pct %>%</div>
    <div class="bar-track"><div class="bar-fill <%= disk.pct>85?'danger':disk.pct>65?'warn':'' %>" style="width:<%= disk.pct %>%"></div></div>
  </div>
  <div class="info-card">
    <div class="info-label">Free</div>
    <div class="info-value"><%= kb(disk.avail) %></div>
    <div class="info-sub"><%= 100 - disk.pct %>% available</div>
  </div>
  <% } %>
  <div class="info-card">
    <div class="info-label">Attached to</div>
    <div class="info-value" style="font-size:.9rem"><%= linodeVolume.linode_label || '—' %></div>
    <div class="info-sub">ID <%= linodeVolume.linode_id || '—' %></div>
  </div>
  <div class="info-card">
    <div class="info-label">Created</div>
    <div class="info-value" style="font-size:.82rem"><%= fmtDate(linodeVolume.created) %></div>
  </div>
</div>
<% } %>

<!-- Backup folders -->
<h2 style="font-size:1rem;margin-bottom:.5rem">Backup folders <span style="font-weight:400;font-size:.8rem;color:var(--muted)">server02.technologyfoc.us/backups</span></h2>
<div class="card" style="padding:0;overflow:hidden">
  <% if (!backups.length) { %>
    <p class="empty" style="padding:2rem 1rem">No backups yet.</p>
  <% } else { %>
  <table class="bk-table">
    <thead><tr><th>Date</th><th>Files</th><th>Size</th><th></th></tr></thead>
    <tbody>
      <% backups.forEach(b => { %>
      <tr>
        <td><%= b.date %></td>
        <td style="color:var(--muted)"><%= b.files %></td>
        <td><%= b.mb %> MB</td>
        <td style="text-align:right"><a href="/volume/backup/<%= b.raw %>" class="btn btn-sm">Browse</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('partials/foot') %>
