<%
  pageTitle = 'Settings';
-%>
<%- include('partials/head') %>

<div class="page-header">
  <h1>Site Settings</h1>
  <div class="header-actions">
    <button form="settings-form" type="submit" class="btn btn-primary">Save &amp; restart</button>
  </div>
</div>

<%- include('partials/flash') %>

<form id="settings-form" method="POST" action="/server/settings">
  <div class="card" style="max-width:640px">

    <div style="display:flex;flex-direction:column;gap:1.1rem">

      <label>
        <span class="field-label">Site title</span>
        <input type="text" name="SITE_TITLE" value="<%= site.title %>" required>
      </label>

      <label>
        <span class="field-label">Site description</span>
        <span class="hint">Used as default meta description and OG description</span>
        <textarea name="SITE_DESCRIPTION" rows="3" style="resize:vertical"><%= site.description %></textarea>
      </label>

      <label>
        <span class="field-label">Author name</span>
        <input type="text" name="SITE_AUTHOR" value="<%= site.author %>">
      </label>

      <label>
        <span class="field-label">Site URL</span>
        <input type="url" name="SITE_URL" value="<%= site.url %>">
      </label>

      <label>
        <span class="field-label">Google Analytics ID</span>
        <span class="hint">Format: G-XXXXXXXXXX — leave blank to disable</span>
        <input type="text" name="GA_ID" value="<%= site.gaId || '' %>" placeholder="G-XXXXXXXXXX">
      </label>

      <label class="checkbox-label">
        <input type="checkbox" name="HIDE_AUTHOR" value="1" <%= site.hideAuthor ? 'checked' : '' %>>
        Hide author name in footer
      </label>

    </div>
  </div>
</form>

<style>
.field-label { display:block; font-size:.78rem; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.3rem; }
.hint { display:block; font-size:.78rem; color:var(--muted); margin-bottom:.3rem; }
</style>

<%- include('partials/foot') %>
