<%
  pageTitle = 'Sites';
  const stateColor = { live:'#16a34a', parked:'#6b7280', redirect:'#2563eb' };
  const stateBg    = { live:'#dcfce7', parked:'#f3f4f6', redirect:'#dbeafe' };
-%>
<%- include('partials/head') %>

<style>
.stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; margin-bottom:1.25rem; }
@media (max-width:600px){ .stats-grid{ grid-template-columns:repeat(2,1fr) } }
.stat-card { background:var(--surface,#fff); border:1px solid var(--border); border-radius:8px; padding:.75rem 1rem; text-decoration:none; color:var(--text); }
.stat-card:hover { border-color:#2563eb; }
.stat-card .v { font-size:1.5rem; font-weight:700; line-height:1; }
.stat-card .l { font-size:.75rem; color:var(--muted); margin-top:.25rem; }

.toolbar { display:flex; gap:.65rem; flex-wrap:wrap; align-items:center; margin-bottom:1rem; }
.toolbar input[type=text] { flex:1; min-width:220px; padding:.4rem .65rem; font-size:.88rem; }
.chip { padding:.3rem .65rem; font-size:.78rem; border-radius:999px; border:1px solid var(--border); background:var(--surface,#fff); color:var(--muted); cursor:pointer; text-decoration:none; font-weight:500; }
.chip.active { background:#2563eb; border-color:#2563eb; color:#fff; }

.sites-table { width:100%; border-collapse:collapse; font-size:.88rem; }
.sites-table th { text-align:left; padding:.55rem .75rem; color:var(--muted); font-weight:600; font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; border-bottom:1px solid var(--border); white-space:nowrap; }
.sites-table td { padding:.55rem .75rem; border-bottom:1px solid var(--border); vertical-align:middle; }
.sites-table tr:hover td { background:var(--surface2,#fafafa); }
.state-badge { display:inline-block; padding:.15em .55em; border-radius:4px; font-size:.72rem; font-weight:700; }
.ssl-dot { display:inline-block; width:8px; height:8px; border-radius:50%; }

.row-form { display:flex; gap:.4rem; flex-wrap:wrap; align-items:center; }
.row-form input, .row-form select { font-size:.8rem; padding:.25rem .45rem; }

.add-row { display:flex; gap:.5rem; align-items:flex-end; flex-wrap:wrap; }
.add-row input, .add-row select { height:2rem; padding:0 .55rem; font-size:.82rem; }
.add-row label { font-size:.72rem; color:var(--muted); display:block; margin-bottom:.2rem; }
.add-row .f { display:flex; flex-direction:column; }
</style>

<div class="page-header">
  <div>
    <h1>Sites</h1>
    <div style="color:var(--muted); font-size:.85rem; margin-top:.25rem">
      <%= counts.total %> domains
    </div>
  </div>
  <div style="display:flex; gap:.5rem">
    <form method="POST" action="/sites/sync-all" style="display:inline" onsubmit="return confirm('Push registry state to nginx for ALL <%= counts.total %> domains?')">
      <button type="submit" class="btn">⟳ Sync all to nginx</button>
    </form>
  </div>
</div>

<%- include('partials/flash') %>

<!-- Stats -->
<div class="stats-grid">
  <a href="/sites" class="stat-card">
    <div class="v"><%= counts.total %></div>
    <div class="l">Total</div>
  </a>
  <a href="/sites?state=live" class="stat-card">
    <div class="v" style="color:#16a34a"><%= counts.live %></div>
    <div class="l">Live</div>
  </a>
  <a href="/sites?state=redirect" class="stat-card">
    <div class="v" style="color:#2563eb"><%= counts.redirect %></div>
    <div class="l">Redirect</div>
  </a>
  <a href="/sites?state=parked" class="stat-card">
    <div class="v" style="color:#6b7280"><%= counts.parked %></div>
    <div class="l">Parked</div>
  </a>
</div>

<!-- Provision new sub-site (full bootstrap) -->
<details class="card" style="padding:1rem; margin-bottom:1rem">
  <summary style="cursor:pointer; font-weight:600; font-size:.85rem; color:#16a34a">⚡ Provision new live sub-site</summary>
  <form method="POST" action="/sites/provision" style="margin-top:.75rem" onsubmit="return confirm('Provision a new sub-site? Creates dir, app.js, .env, systemd unit, nginx config, SSL cert.')">
    <div class="add-row">
      <div class="f"><label>Domain</label>
        <input type="text" name="domain" placeholder="example.com" required style="width:200px"></div>
      <div class="f"><label>Port (1024-65535)</label>
        <input type="number" name="port" placeholder="4092" min="1024" max="65535" required style="width:100px"></div>
      <div class="f"><label>Title</label>
        <input type="text" name="title" placeholder="Site title" style="width:200px"></div>
      <button type="submit" class="btn btn-primary">⚡ Provision</button>
    </div>
    <p style="font-size:.72rem; color:var(--muted); margin-top:.5rem">
      Creates <code>/var/www/technologyfoc.us/sites/&lt;domain&gt;/</code>, a systemd unit, nginx config, and an SSL cert. DNS for the domain must already point to this server.
    </p>
  </form>
</details>

<!-- Add existing domain to registry (no provisioning) -->
<details class="card" style="padding:1rem; margin-bottom:1rem">
  <summary style="cursor:pointer; font-weight:600; font-size:.85rem">+ Add domain (registry only)</summary>
  <form method="POST" action="/sites/add" style="margin-top:.75rem">
    <div class="add-row">
      <div class="f"><label>Domain</label>
        <input type="text" name="domain" placeholder="example.com" required style="width:200px"></div>
      <div class="f"><label>State</label>
        <select name="state" onchange="document.getElementById('addTgt').style.display=this.value==='redirect'?'':'none';document.getElementById('addPort').style.display=this.value==='live'?'':'none'">
          <option value="parked">parked</option>
          <option value="redirect">redirect</option>
          <option value="live">live</option>
        </select></div>
      <div class="f" id="addTgt" style="display:none"><label>Target URL</label>
        <input type="text" name="target" placeholder="https://andresanz.com" style="width:220px"></div>
      <div class="f" id="addPort" style="display:none"><label>Port</label>
        <input type="number" name="port" placeholder="4092" style="width:80px"></div>
      <div class="f"><label>Note</label>
        <input type="text" name="note" placeholder="optional" style="width:160px"></div>
      <button type="submit" class="btn btn-primary">Add</button>
    </div>
  </form>
</details>

<!-- Search -->
<form method="GET" action="/sites" class="toolbar">
  <input type="text" name="q" value="<%= q %>" placeholder="Search domains…">
  <% if (stateFilter) { %><input type="hidden" name="state" value="<%= stateFilter %>"><% } %>
  <button type="submit" class="btn">Search</button>
  <% if (q || stateFilter) { %>
    <a href="/sites" class="chip">× clear</a>
  <% } %>
</form>

<!-- Table -->
<div class="card" style="padding:0; overflow:hidden">
  <% if (!sites.length) { %>
    <p style="padding:2rem; color:var(--muted); text-align:center">No domains match.</p>
  <% } else { %>
  <table class="sites-table">
    <thead>
      <tr>
        <th>Domain</th>
        <th>SSL</th>
        <th>State</th>
        <th>Target / Port</th>
        <th>Note</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    <% sites.forEach(s => { %>
      <tr>
        <td>
          <a href="https://<%= s.domain %>" target="_blank" rel="noopener" style="font-weight:600; text-decoration:none; color:var(--text)"><%= s.domain %></a>
        </td>
        <td>
          <% if (s.ssl_active) { %>
            <span class="ssl-dot" style="background:#16a34a" title="cert present"></span>
          <% } else { %>
            <form method="POST" action="/sites/<%= s.domain %>/ssl" style="display:inline" onsubmit="return confirm('Issue SSL cert for <%= s.domain %>? Requires DNS pointing here.')">
              <button type="submit" class="btn btn-sm" style="font-size:.7rem; padding:.15rem .4rem" title="issue cert">🔓 SSL</button>
            </form>
          <% } %>
        </td>
        <td>
          <span class="state-badge" style="background:<%= stateBg[s.state] %>; color:<%= stateColor[s.state] %>"><%= s.state %></span>
        </td>
        <td style="font-size:.78rem; color:var(--muted); max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
          <% if (s.state === 'redirect') { %>→ <%= s.target || '—' %><% } %>
          <% if (s.state === 'live') { %>:<%= s.port || '—' %><% if (s.runtime) { %> <span style="color:#16a34a">●</span><% } %><% } %>
          <% if (s.state === 'parked') { %>—<% } %>
        </td>
        <td style="color:var(--muted); font-size:.78rem; max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"><%= s.note || '' %></td>
        <td>
          <details>
            <summary style="cursor:pointer; font-size:.78rem; color:#2563eb">edit</summary>
            <form method="POST" action="/sites/<%= s.domain %>/save" class="row-form" style="margin-top:.5rem">
              <select name="state">
                <% ['live','redirect','parked'].forEach(st => { %>
                  <option value="<%= st %>" <%= s.state===st?'selected':'' %>><%= st %></option>
                <% }) %>
              </select>
              <input type="text"   name="target" value="<%= s.target || '' %>" placeholder="target URL" style="width:180px">
              <input type="number" name="port"   value="<%= s.port || '' %>"   placeholder="port"      style="width:70px">
              <label style="font-size:.75rem" title="Append the original request path to redirect target"><input type="checkbox" name="preserve_path" value="1" <%= s.preserve_path?'checked':'' %>> path</label>
              <label style="font-size:.75rem" title="Sync to nginx (uncheck to leave config hand-managed)"><input type="checkbox" name="nginx_managed" value="1" <%= s.nginx_managed?'checked':'' %>> nginx</label>
              <input type="text"   name="note"   value="<%= s.note || '' %>"   placeholder="note"      style="width:140px">
              <button type="submit" class="btn btn-sm">save</button>
            </form>
            <div style="margin-top:.4rem; display:flex; gap:.3rem">
              <form method="POST" action="/sites/<%= s.domain %>/sync" style="display:inline">
                <button type="submit" class="btn btn-sm">⟳ sync nginx</button>
              </form>
              <form method="POST" action="/sites/<%= s.domain %>/remove" style="display:inline" onsubmit="return confirm('Remove <%= s.domain %> from registry AND nginx?')">
                <button type="submit" class="btn btn-sm btn-danger">delete</button>
              </form>
            </div>
          </details>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('partials/foot') %>
