<% pageTitle = 'WAF · Server' -%>
<%- include('partials/head') %>

<style>
.waf-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); gap:.6rem; margin-bottom:1.5rem; }
.stat-card  { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:.85rem 1rem; }
.stat-n     { font-size:1.8rem; font-weight:700; line-height:1; }
.stat-l     { font-size:.7rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); margin-top:.2rem; }
.stat-n.red { color:var(--danger); }

.mode-bar   { display:flex; align-items:center; gap:.75rem; margin-bottom:1.5rem; flex-wrap:wrap; }
.mode-badge { display:inline-block; padding:.25em .75em; border-radius:999px; font-size:.8rem; font-weight:700; letter-spacing:.03em; }
.mode-detecting { background:#fef9c3; color:#854d0e; border:1px solid #fde047; }
.mode-blocking  { background:#dcfce7; color:#166534; border:1px solid #86efac; }
.mode-off       { background:var(--surface); color:var(--muted); border:1px solid var(--border); }

.section-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); margin:1.5rem 0 .6rem; }

.event-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.event-table th { text-align:left; padding:.45rem .75rem; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); border-bottom:1px solid var(--border); }
.event-table td { padding:.45rem .75rem; border-bottom:1px solid var(--border); vertical-align:top; }
.event-table tr:last-child td { border-bottom:none; }
.ts-cell    { color:var(--muted); white-space:nowrap; font-size:.75rem; }
.ip-cell    { font-family:var(--mono); font-size:.78rem; }
.uri-cell   { font-family:var(--mono); font-size:.75rem; color:var(--muted); max-width:320px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block; }
.req-cell   { max-width:340px; }
.rule-pill  { display:inline-block; padding:.1em .45em; border-radius:4px; background:#fef2f2; border:1px solid #fecaca; font-size:.7rem; font-family:var(--mono); color:#991b1b; margin:.1em .1em 0 0; white-space:nowrap; }
.rules-cell { max-width:200px; }
.sev-critical { color:#991b1b; font-weight:700; }
.sev-error    { color:var(--danger); }
.sev-warning  { color:#b45309; }
.sev-notice   { color:var(--muted); }

.excl-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.excl-table th { text-align:left; padding:.45rem .75rem; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); border-bottom:1px solid var(--border); }
.excl-table td { padding:.45rem .75rem; border-bottom:1px solid var(--border); }
.excl-table tr:last-child td { border-bottom:none; }

.excl-form  { display:flex; gap:.5rem; flex-wrap:wrap; align-items:flex-end; margin-bottom:1.5rem; }
.excl-form select, .excl-form input { padding:.4rem .6rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); color:var(--text); font-size:.875rem; }
.excl-form input[name=value] { width:220px; font-family:var(--mono); }
.excl-form input[name=note]  { width:180px; }
.type-badge { display:inline-block; padding:.1em .5em; border-radius:4px; font-size:.72rem; border:1px solid var(--border); background:var(--surface); color:var(--muted); }

.top-list { list-style:none; padding:0; margin:0; font-size:.82rem; }
.top-list li { display:flex; justify-content:space-between; padding:.3rem 0; border-bottom:1px solid var(--border); }
.top-list li:last-child { border-bottom:none; }
.top-list code { font-family:var(--mono); font-size:.78rem; }
.top-list .cnt { font-weight:700; color:var(--danger); }

.not-installed { text-align:center; padding:4rem 0; color:var(--muted); }
.not-installed h2 { color:var(--text); margin-bottom:.5rem; }
.not-installed pre { text-align:left; display:inline-block; background:var(--surface); border:1px solid var(--border); padding:1rem 1.5rem; border-radius:var(--radius); font-size:.85rem; margin-top:1.5rem; }
</style>

<div class="page-header">
  <div><h1>WAF</h1></div>
  <div class="header-actions">
    <a href="/logs?source=sysfile&file=nginx%2Fmodsec_audit.log" class="btn">Raw log</a>
  </div>
</div>

<%- include('partials/flash') %>

<% if (!installed) { %>
<div class="not-installed">
  <h2>ModSecurity not installed</h2>
  <p>Run the setup script on the server to enable the WAF.</p>
  <pre>sudo bash /var/www/technologyfoc.us/scripts/setup-modsec.sh</pre>
</div>
<% } else { %>

<!-- Mode bar -->
<div class="mode-bar">
  <strong style="font-size:.9rem">Mode:</strong>
  <span class="mode-badge <%= mode === 'On' ? 'mode-blocking' : mode === 'DetectionOnly' ? 'mode-detecting' : 'mode-off' %>">
    <%= mode === 'On' ? '🛡 Blocking' : mode === 'DetectionOnly' ? '👁 Detection Only' : '⭕ Off' %>
  </span>
  <form method="POST" action="/waf/mode" style="display:inline-flex;gap:.4rem">
    <% if (mode !== 'DetectionOnly') { %>
      <button name="mode" value="DetectionOnly" class="btn btn-sm">Detection</button>
    <% } %>
    <% if (mode !== 'On') { %>
      <button name="mode" value="On" class="btn btn-sm btn-primary">Blocking</button>
    <% } %>
    <% if (mode !== 'Off') { %>
      <button name="mode" value="Off" class="btn btn-sm btn-danger">Disable</button>
    <% } %>
  </form>
</div>

<!-- Stats -->
<div class="waf-stats">
  <div class="stat-card">
    <div class="stat-n <%= stats.today > 0 ? 'red' : '' %>"><%= stats.today %></div>
    <div class="stat-l">Events today</div>
  </div>
  <div class="stat-card">
    <div class="stat-n"><%= stats.total %></div>
    <div class="stat-l">Total in log</div>
  </div>
  <div class="stat-card">
    <div class="stat-n"><%= stats.loaded %></div>
    <div class="stat-l">Loaded (last 200)</div>
  </div>
  <div class="stat-card" style="grid-column:span 2">
    <div class="stat-l" style="margin-bottom:.5rem">Top IPs</div>
    <% if (stats.topIps.length) { %>
    <ul class="top-list">
      <% stats.topIps.forEach(function(r) { %>
      <li>
        <code title="<%= r.country %>"><% if (r.flag) { %><%= r.flag %> <% } %><%= r.ip %></code>
        <span class="cnt"><%= r.cnt %></span>
      </li>
      <% }) %>
    </ul>
    <% } else { %><div style="color:var(--muted);font-size:.8rem">None</div><% } %>
  </div>
  <div class="stat-card" style="grid-column:span 2">
    <div class="stat-l" style="margin-bottom:.5rem">Top rules</div>
    <% if (stats.topRules.length) { %>
    <ul class="top-list">
      <% stats.topRules.forEach(([rule, cnt]) => { %>
      <li><code><%= rule %></code><span class="cnt"><%= cnt %></span></li>
      <% }) %>
    </ul>
    <% } else { %><div style="color:var(--muted);font-size:.8rem">None</div><% } %>
  </div>
</div>

<!-- Timeline chart -->
<div class="section-title">Events over time</div>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem;margin-bottom:1.5rem;position:relative;min-height:120px">
  <canvas id="timelineChart" height="90"></canvas>
  <div id="timelineEmpty" style="display:none;color:var(--muted);font-size:.85rem;text-align:center;padding:2rem 0">No data yet</div>
</div>

<!-- Event log -->
<div class="section-title" style="display:flex;align-items:center;gap:.75rem">
  Recent events
  <span id="live-dot" style="width:7px;height:7px;border-radius:50%;background:#16a34a;display:inline-block;animation:pulse 2s infinite"></span>
</div>
<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}</style>

<div style="border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:2rem">
  <div style="max-height:60vh;overflow-y:auto">
  <table class="event-table" id="evTable" style="table-layout:fixed;width:100%">
    <thead style="position:sticky;top:0;background:var(--surface);z-index:1;box-shadow:0 1px 0 var(--border)"><tr><th>Time</th><th>IP</th><th>Request</th><th>Rules triggered</th></tr></thead>
    <tbody id="evBody">
      <% if (!events.length) { %>
      <tr><td colspan="4" style="color:var(--muted);padding:1rem">No events yet — ModSecurity is running in <%= mode %> mode</td></tr>
      <% } else { %>
      <% events.forEach(function(e) { %>
      <tr>
        <td class="ts-cell"><%= e.time || '' %></td>
        <td class="ip-cell"><% if (e.flag) { %><span style="margin-right:.3em"><%= e.flag %></span><% } %><%= e.ip %></td>
        <td class="req-cell">
          <span style="font-size:.75rem;font-weight:600"><%= e.method %></span>
          <span class="uri-cell" title="<%= e.uri %>"><%= e.uri %></span>
          <% if (e.status) { %><span style="font-size:.72rem;color:var(--muted)"> → <%= e.status %></span><% } %>
        </td>
        <td class="rules-cell">
          <% e.messages.forEach(function(m) { %>
            <a class="rule-pill" title="<%= m.msg %>" href="https://github.com/coreruleset/coreruleset/search?q=<%= m.id %>&type=code" target="_blank">
              <%= m.id %><% if (m.severity) { %> <span class="sev-<%= m.severity.toLowerCase() %>">·<%= m.severity.slice(0,4) %></span><% } %>
            </a>
          <% }) %>
        </td>
      </tr>
      <% }) %>
      <% } %>
    </tbody>
  </table>
  </div>
</div>

<!-- Block rules -->
<div class="section-title">Block Rules</div>

<form method="POST" action="/waf/blocks/add" class="excl-form">
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Type</label>
    <select name="type">
      <option value="uri">URI contains</option>
      <option value="ip">IP address</option>
      <option value="ua">User-Agent contains</option>
    </select>
  </div>
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Value</label>
    <input type="text" name="value" placeholder="e.g. wp-login.php / 1.2.3.4 / zgrab" required>
  </div>
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Note</label>
    <input type="text" name="note" placeholder="Reason (optional)">
  </div>
  <button class="btn btn-danger">Add block</button>
</form>

<% if (blocks && blocks.length) { %>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:2rem">
  <table class="excl-table">
    <thead><tr><th>Type</th><th>Value</th><th>Note</th><th>Added</th><th></th></tr></thead>
    <tbody>
      <% blocks.forEach(function(b) { %>
      <tr>
        <td><span class="type-badge"><%= b.type %></span></td>
        <td><code style="font-size:.8rem;font-family:var(--mono)"><%= b.value %></code></td>
        <td style="color:var(--muted);font-size:.8rem"><%= b.note %></td>
        <td class="ts-cell"><%= b.createdAt ? b.createdAt.slice(0,10) : '' %></td>
        <td>
          <form method="POST" action="/waf/blocks/delete" style="display:inline">
            <input type="hidden" name="id" value="<%= b.id %>">
            <button class="btn btn-sm btn-danger" onclick="return confirm('Remove block rule?')">Remove</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } else { %>
<p style="color:var(--muted);font-size:.85rem;margin-bottom:2rem">No block rules yet.</p>
<% } %>

<!-- Exclusions -->
<div class="section-title">Exclusions / Whitelist</div>

<form method="POST" action="/waf/exclusions/add" class="excl-form">
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Type</label>
    <select name="type">
      <option value="ip">IP address</option>
      <option value="rule">Rule ID</option>
      <option value="path">Path prefix</option>
    </select>
  </div>
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Value</label>
    <input type="text" name="value" placeholder="e.g. 1.2.3.4 / 941100 / /api/" required>
  </div>
  <div>
    <label style="font-size:.75rem;font-weight:600;display:block;margin-bottom:.25rem">Note</label>
    <input type="text" name="note" placeholder="Reason (optional)">
  </div>
  <button class="btn btn-primary">Add exclusion</button>
</form>

<% if (exclusions.length) { %>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:2rem">
  <table class="excl-table">
    <thead><tr><th>Type</th><th>Value</th><th>Note</th><th>Added</th><th></th></tr></thead>
    <tbody>
      <% exclusions.forEach(function(e) { %>
      <tr>
        <td><span class="type-badge"><%= e.type %></span></td>
        <td><code style="font-size:.8rem;font-family:var(--mono)"><%= e.value %></code></td>
        <td style="color:var(--muted);font-size:.8rem"><%= e.note %></td>
        <td class="ts-cell"><%= e.createdAt ? e.createdAt.slice(0,10) : '' %></td>
        <td>
          <form method="POST" action="/waf/exclusions/delete" style="display:inline">
            <input type="hidden" name="id" value="<%= e.id %>">
            <button class="btn btn-sm btn-danger" onclick="return confirm('Remove exclusion?')">Remove</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } else { %>
<p style="color:var(--muted);font-size:.85rem">No exclusions yet. Add one above if you get false positives.</p>
<% } %>

<% } %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(async function initTimeline() {
  try {
    const { labels, counts } = await fetch('/waf/timeline').then(r => r.json());
    if (!labels || !labels.length) {
      document.getElementById('timelineEmpty').style.display = 'block';
      document.getElementById('timelineChart').style.display = 'none';
      return;
    }
    const isDark = document.documentElement.classList.contains('dark') ||
                   window.matchMedia('(prefers-color-scheme: dark)').matches;
    const gridColor  = isDark ? 'rgba(255,255,255,.08)' : 'rgba(0,0,0,.07)';
    const labelColor = isDark ? '#9ca3af' : '#6b7280';
    const barColor   = 'rgba(220,38,38,.75)';
    const ctx = document.getElementById('timelineChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{ data: counts, backgroundColor: barColor, borderRadius: 3, borderSkipped: false }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { legend: { display: false }, tooltip: {
          callbacks: { title: t => t[0].label, label: t => `${t.raw} event${t.raw !== 1 ? 's' : ''}` }
        }},
        scales: {
          x: { ticks: { color: labelColor, font: { size: 11 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 14 }, grid: { color: gridColor } },
          y: { ticks: { color: labelColor, font: { size: 11 }, precision: 0 }, grid: { color: gridColor }, beginAtZero: true }
        }
      }
    });
  } catch (err) {
    document.getElementById('timelineEmpty').style.display = 'block';
    document.getElementById('timelineChart').style.display = 'none';
  }
})();
</script>

<script>
let lastTs = '<%= events[0] ? (events[0].time||'').slice(0,19) : "" %>';

function sevClass(s) {
  s = (s||'').toLowerCase();
  if (s === 'critical') return 'sev-critical';
  if (s === 'error')    return 'sev-error';
  if (s === 'warning')  return 'sev-warning';
  return 'sev-notice';
}

async function pollEvents() {
  try {
    const data = await fetch('/waf/events').then(r => r.json());
    if (!data.length) return;
    const newTs = (data[0].time||'').slice(0,19);
    if (newTs === lastTs) return;
    lastTs = newTs;
    document.getElementById('evBody').innerHTML = data.map(e => `
      <tr>
        <td class="ts-cell">${e.time||''}</td>
        <td class="ip-cell">${e.flag ? `<span style="margin-right:.3em">${e.flag}</span>` : ''}${e.ip||''}</td>
        <td>
          <span style="font-size:.75rem;font-weight:600">${e.method||''}</span>
          <span class="uri-cell" title="${e.uri||''}"> ${e.uri||''}</span>
          ${e.status ? `<span style="font-size:.72rem;color:var(--muted)"> → ${e.status}</span>` : ''}
        </td>
        <td>${(e.messages||[]).map(m =>
          `<a class="rule-pill" title="${m.msg||''}" href="https://github.com/coreruleset/coreruleset/search?q=${m.id||''}&type=code" target="_blank">${m.id||''}${m.severity ? ` <span class="${sevClass(m.severity)}">·${m.severity.slice(0,4)}</span>` : ''}</a>`
        ).join('')}</td>
      </tr>`).join('');
  } catch {}
}
setInterval(pollEvents, 10000);
</script>

<%- include('partials/foot') %>
