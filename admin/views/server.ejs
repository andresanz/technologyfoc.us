</div>

<% if (commits && commits.length) { %>
<div class="section-header">
  <h2 style="font-size:.875rem">Recent commits</h2>
</div>
<div class="card" style="padding:0; margin-bottom:1.5rem">
  <table style="width:100%;font-size:.8rem;border-collapse:collapse">
    <tbody>
      <% commits.slice(0,5).forEach(function(c) { %>
      <tr>
        <td style="padding:.35rem .75rem;border-bottom:1px solid var(--border);color:var(--muted);white-space:nowrap;width:110px"><%= c.date %></td>
        <td style="padding:.35rem .75rem;border-bottom:1px solid var(--border)"><%= c.message %></td>
        <td style="padding:.35rem .75rem;border-bottom:1px solid var(--border);text-align:right"><code style="font-size:.72rem;color:var(--muted)"><%= c.hash %></code></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<% if (siteLogs && siteLogs.length) { %>
<div class="section-header">
  <h2 style="font-size:.875rem">Service logs <span style="font-weight:400;color:var(--muted)">(last 30 lines)</span></h2>
</div>
<div class="card" style="padding:.75rem 1rem; margin-bottom:1.5rem">
  <pre style="font-size:.72rem;line-height:1.5;overflow-x:auto;margin:0;white-space:pre-wrap;word-break:break-all"><%= siteLogs %></pre>
</div>
<% } %>

<script>
document.getElementById('bustCacheBtn').addEventListener('click', async function() {
  this.disabled = true;
  this.textContent = 'Busting…';
  const r = await fetch('/server/site/bust-cache', { method: 'POST' });
  this.textContent = r.ok ? 'Cache cleared ✓' : 'Failed ✗';
  setTimeout(() => { this.textContent = 'Bust cache'; this.disabled = false; }, 2000);
});
</script>

<script>
// Auto-refresh metrics every 10 seconds
async function refreshMetrics() {
  try {
    const d = await (await fetch('/server/stats')).json();
    const kb = v => v >= 1048576 ? (v/1048576).toFixed(1)+' GB' : v >= 1024 ? (v/1024).toFixed(0)+' MB' : v+' KB';
    const pct = (u,t) => t ? Math.round(u/t*100) : 0;

    const memPct = pct(d.memUsed, d.memTotal);
    set('m-mem-val', kb(d.memUsed));
    set('m-mem-sub', `of ${kb(d.memTotal)} · ${memPct}%`);
    setBar('m-mem-bar', memPct);

    const loadPct = Math.round(Math.min(d.load1 / d.cpus * 100, 100));
    set('m-load-val', d.load1.toFixed(2));
    set('m-load-sub', `${d.load5.toFixed(2)} / ${d.load15.toFixed(2)} · ${d.cpus} CPU`);
    setBar('m-load-bar', loadPct);
  } catch {}
}
function set(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
function setBar(id, pct) {
  const el = document.getElementById(id); if (!el) return;
  el.style.width = pct + '%';
  el.className = 'bar-fill' + (pct>85?' danger':pct>65?' warn':'');
}
setInterval(refreshMetrics, 10000);

// Health badge — poll /server/health every 30s
async function refreshHealth() {
  try {
    const d = await fetch('/server/health', {headers:{Accept:'application/json'}}).then(r=>r.json());
    const el = document.getElementById('health-badge');
    if (!el) return;
    const map = {ok:'health-ok', warning:'health-warn', critical:'health-crit', error:'health-crit'};
    const labels = {ok:'All healthy', warning:'Warning', critical:'Critical', error:'Error'};
    el.className = 'health-badge ' + (map[d.overall] || 'health-ok');
    el.textContent = labels[d.overall] || d.overall;
    el.title = d.alerts && d.alerts.length ? d.alerts.join(', ') : 'All checks passing';
  } catch {}
}
refreshHealth();
setInterval(refreshHealth, 30000);
</script>

<%- include('partials/foot') %>
