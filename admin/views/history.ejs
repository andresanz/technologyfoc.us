<%
  pageTitle = 'History · ' + site.title;
-%>
<%- include('partials/head') %>

<div class="page-header">
  <div>
    
    <h1>History <span class="muted">— <%= site.domain %></span></h1>
  </div>
</div>
<%- include('partials/flash') %>

<% if (!commits.length) { %>
  <p class="muted">No commits yet.</p>
<% } else { %>
  <section class="card" style="padding:0">
    <table class="post-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Change</th>
          <th>Commit</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% commits.forEach(function(c) { %>
          <tr>
            <td style="white-space:nowrap;color:var(--muted);font-size:.8rem"><%= c.date %></td>
            <td><%= c.message %></td>
            <td><code style="font-size:.75rem;color:var(--muted)"><%= c.hash %></code></td>
            <td>
              <a href="/server/history/<%= c.hash %>" class="btn btn-sm">View</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
<% } %>

<%- include('partials/foot') %>
