<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%2032%2032'%3E%3Crect%20width%3D'32'%20height%3D'32'%20rx%3D'7'%20fill%3D'%232563eb'%2F%3E%3C%2Fsvg%3E">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · ' : '' %>Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<nav class="topnav">
  <div class="nav-inner">
    <a href="/server" class="nav-brand">⚙ Admin<% if (typeof gitHash !== 'undefined' && gitHash) { %> <span style="font-size:0.65em;opacity:0.45;font-weight:400"><%= gitHash %></span><% } %></a>
    <% if (typeof editableSites !== 'undefined' && editableSites.length > 1) { %>
      <form method="POST" action="/switch-site" class="site-switcher" id="siteSwitcherForm">
        <select name="domain" onchange="document.getElementById('siteSwitcherForm').submit()" class="site-switcher-select" title="Switch active site">
          <% editableSites.forEach(function(s) { %>
            <option value="<%= s.domain %>" <%= s.domain === activeSite ? 'selected' : '' %>><%= s.domain %></option>
          <% }) %>
        </select>
      </form>
    <% } %>
    <button class="nav-hamburger" id="navToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="navLinks">

      <a href="/write" class="nav-cta">Write</a>
      <form method="GET" action="/search" class="nav-search">
        <input type="text" name="q" placeholder="🔍 Search…" value="<%= typeof q !== 'undefined' ? q : '' %>">
      </form>

      <div class="nav-drop">
        <button class="nav-drop-btn" data-drop="content">Content ▾</button>
        <div class="nav-drop-menu" data-drop-menu="content">
          <a href="/posts">Posts</a>
          <a href="/pages">Pages</a>
          <a href="/media">Media</a>
          <a href="/posts/tags">Tags</a>
          <a href="/server/nav">Nav</a>
          <a href="/server/css">CSS</a>
          <a href="/gratitude-prompts">Gratitude</a>
          <a href="/templates">Templates</a>
          <a href="/links">Links</a>
        </div>
      </div>

      <div class="nav-drop">
        <button class="nav-drop-btn" data-drop="insights">Insights ▾</button>
        <div class="nav-drop-menu" data-drop-menu="insights">
          <a href="/analytics">Analytics</a>
          <a href="/server/history">History</a>
        </div>
      </div>

      <div class="nav-drop">
        <button class="nav-drop-btn" data-drop="platform">Platform ▾</button>
        <div class="nav-drop-menu" data-drop-menu="platform">
          <a href="/sites">Sites</a>
          <a href="/domains">Domains (DNS)</a>
          <a href="/waf">WAF</a>
          <a href="/server/webhooks">Webhooks</a>
          <a href="/cron">Cron</a>
          <a href="/server/backups">Backups</a>
          <a href="/s3">S3</a>
          <a href="/github">GitHub</a>
        </div>
      </div>

      <div class="nav-drop">
        <button class="nav-drop-btn" data-drop="server">Server ▾</button>
        <div class="nav-drop-menu" data-drop-menu="server">
          <a href="/server">Health</a>
          <a href="/server/logs">Logs</a>
          <a href="/server/bans">Bans</a>
          <a href="/server/nginx">Nginx</a>
          <a href="/mac">Mac mounts</a>
          <a href="/volume">Volume</a>
        </div>
      </div>

      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn-link">Sign out</button>
      </form>
    </div>
  </div>
</nav>
<script>
  document.getElementById('navToggle').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('navLinks').classList.toggle('open');
  });
  // Multi-dropdown: clicking a button opens its menu and closes the others
  document.querySelectorAll('.nav-drop-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var parent = btn.parentElement;
      var wasOpen = parent.classList.contains('open');
      document.querySelectorAll('.nav-drop.open').forEach(function(d) { d.classList.remove('open'); });
      if (!wasOpen) parent.classList.add('open');
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('.nav-drop.open').forEach(function(d) { d.classList.remove('open'); });
  });
</script>
<main>
