<%
  locals.pageTitle = tag ? 'Posts tagged "' + tag + '"' : null;
  locals.pageDesc  = site.description;
  locals.canonical = tag ? '/tag/' + tag : (page > 1 ? '/?page=' + page : '/');
-%>
<%- include('layout') %>

<div class="page-header">
  <% if (tag) { %>
    <h1>Posts tagged <span class="tag-highlight"><%= tag %></span></h1>
  <% } else { %>
    <h1>Posts</h1>
    <p class="site-desc"><%= site.description %></p>
  <% } %>
</div>

<div class="post-list">
  <% if (posts.length === 0) { %>
    <p class="empty">No posts yet.</p>
  <% } else { %>
    <% posts.forEach(function(post) { %>
      <article class="post-card">
        <% if (post.coverImage) { %>
          <a href="/post/<%= post.slug %>" class="post-cover">
            <img src="<%= post.coverImage %>" alt="<%= post.title %>">
          </a>
        <% } %>
        <div class="post-card-body">
          <div class="post-meta">
            <time datetime="<%= post.dateISO %>"><%= post.dateStr %></time>
            <% post.tags.forEach(function(t) { %>
              <a href="/tag/<%= t %>" class="tag"><%= t %></a>
            <% }) %>
          </div>
          <h2><a href="/post/<%= post.slug %>"><%= post.title %></a></h2>
          <% var ex = post.excerpt || ''; var truncated = ex.length > 140 ? ex.slice(0, 137) + '…' : ex; %>
          <% if (truncated) { %><p class="excerpt"><%= truncated %></p><% } %>
          <a href="/post/<%= post.slug %>" class="read-more">Read more →</a>
        </div>
      </article>
    <% }) %>
  <% } %>
</div>

<% if (totalPages > 1) { %>
  <nav class="pagination">
    <% if (page > 1) { %>
      <a href="?page=<%= page - 1 %><%= tag ? '&tag=' + tag : '' %>" class="prev">← Newer</a>
    <% } else { %><span></span><% } %>
    <span>Page <%= page %> of <%= totalPages %></span>
    <% if (page < totalPages) { %>
      <a href="?page=<%= page + 1 %><%= tag ? '&tag=' + tag : '' %>" class="next">Older →</a>
    <% } else { %><span></span><% } %>
  </nav>
<% } %>

<%- include('layout-end') %>
