<%
  const activeDomain = site ? site.domain : '';
  const activeTitle  = site ? site.title  : '';
-%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#f9f7f4">
  <title>Write</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --paper:   #f9f7f4;
      --ink:     #1a1917;
      --faint:   #e8e4de;
      --ghost:   #b0a99e;
      --accent:  #1a1917;
      --blue:    #2563eb;
      --red:     #c0392b;
      --r: 12px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --serif: Georgia, 'Times New Roman', serif;
    }

    html { height: 100%; }
    body {
      height: 100%; background: var(--paper);
      font-family: var(--font); color: var(--ink);
      -webkit-font-smoothing: antialiased;
      overscroll-behavior: none;
    }

    /* ── Top nav ── */
    .topnav {
      position: sticky; top: 0; z-index: 20;
      display: flex; align-items: center; gap: .5rem;
      padding: .5rem .9rem;
      padding-top: max(.5rem, env(safe-area-inset-top));
      background: rgba(249,247,244,.92);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      backdrop-filter: blur(20px) saturate(180%);
    }

    /* Site chip */
    .site-chip {
      display: inline-flex; align-items: center; gap: .3rem;
      background: var(--faint); border-radius: 999px;
      padding: .3rem .7rem; font-size: .78rem; font-weight: 600;
      color: var(--ink); cursor: pointer; border: none;
      font-family: var(--font); white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
      transition: background .15s;
      max-width: 160px; overflow: hidden; text-overflow: ellipsis;
    }
    .site-chip:active { background: #dcd8d0; }
    .site-chip svg { flex-shrink: 0; }

    .nav-spacer { flex: 1; }

    .nav-btn {
      background: none; border: none; font-family: var(--font);
      font-size: .875rem; color: var(--ghost); cursor: pointer;
      padding: .35rem .5rem; border-radius: 8px;
      -webkit-tap-highlight-color: transparent;
      transition: color .15s;
      white-space: nowrap;
    }
    .nav-btn:active { color: var(--ink); }

    .nav-publish {
      background: var(--ink); color: #fff; border: none;
      font-family: var(--font); font-size: .875rem; font-weight: 600;
      padding: .4rem .95rem; border-radius: 999px; cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: opacity .15s;
      display: flex; align-items: center; gap: .4rem;
      white-space: nowrap;
    }
    .nav-publish:active { opacity: .75; }
    .nav-publish.draft-mode { background: var(--ghost); }

    /* ── Writing surface ── */
    .surface {
      max-width: 680px; margin: 0 auto;
      padding: 1.25rem 1.25rem 0;
      display: flex; flex-direction: column;
    }

    .title-field {
      width: 100%; border: none; background: transparent;
      color: var(--ink); font-family: var(--font);
      font-size: clamp(1.5rem, 5vw, 2rem); font-weight: 700;
      line-height: 1.25; outline: none; resize: none;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
      /* auto-height via JS */
    }
    .title-field::placeholder { color: var(--ghost); }

    .divider { width: 32px; height: 2px; background: var(--faint); margin: 1rem 0; border-radius: 1px; flex-shrink: 0; }

    .body-field {
      width: 100%; border: none; background: transparent;
      color: var(--ink); font-family: var(--serif);
      font-size: 17px; line-height: 1.8; outline: none; resize: none;
      min-height: calc(100dvh - 320px);
      -webkit-font-smoothing: antialiased;
      padding-bottom: 160px; /* space for bottom bar */
    }
    .body-field::placeholder { color: var(--ghost); }

    /* ── Bottom bar (fixed above keyboard) ── */
    .bottom-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 20;
      background: rgba(249,247,244,.96);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      backdrop-filter: blur(20px) saturate(180%);
      border-top: 1px solid var(--faint);
      padding-bottom: env(safe-area-inset-bottom);
    }

    /* Format toolbar */
    .fmt-bar {
      display: flex; align-items: center;
      overflow-x: auto; -webkit-overflow-scrolling: touch;
      padding: .4rem .5rem;
      gap: .1rem;
    }
    .fmt-bar::-webkit-scrollbar { display: none; }

    .fmt-btn {
      flex-shrink: 0;
      background: none; border: none; cursor: pointer;
      color: var(--ink); border-radius: 8px;
      width: 38px; height: 36px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: .85rem; font-family: var(--font); font-weight: 600;
      -webkit-tap-highlight-color: transparent;
      transition: background .1s;
    }
    .fmt-btn:active, .fmt-btn.pressed { background: var(--faint); }
    .fmt-sep { width: 1px; height: 20px; background: var(--faint); margin: 0 .2rem; flex-shrink: 0; }

    /* Meta row (tags + draft toggle) */
    .meta-bar {
      display: flex; align-items: center; gap: .5rem;
      padding: .3rem .75rem .5rem;
      border-top: 1px solid var(--faint);
    }
    .tag-icon { color: var(--ghost); flex-shrink: 0; }
    .tags-field {
      flex: 1; background: none; border: none; outline: none;
      font-family: var(--font); font-size: 14px; color: var(--ink);
    }
    .tags-field::placeholder { color: var(--ghost); }

    .meta-sep { width: 1px; height: 16px; background: var(--faint); }

    .draft-pill {
      display: flex; align-items: center; gap: .3rem;
      background: none; border: 1px solid var(--faint);
      border-radius: 999px; padding: .2rem .6rem;
      font-size: .75rem; font-weight: 600; font-family: var(--font);
      color: var(--ghost); cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: all .15s; white-space: nowrap;
    }
    .draft-pill.active { background: #fef9c3; border-color: #fde68a; color: #92400e; }
    .draft-pill input { display: none; }

    /* Upload icons in fmt bar */
    #uploadStatus {
      font-size: .75rem; color: var(--ghost);
      padding: 0 .3rem; white-space: nowrap; flex-shrink: 0;
    }

    /* ── Toast ── */
    .toast {
      position: fixed; bottom: 6rem; left: 50%; transform: translateX(-50%) translateY(20px);
      background: var(--ink); color: #fff; border-radius: 999px;
      padding: .55rem 1.25rem; font-size: .875rem; font-weight: 500;
      opacity: 0; pointer-events: none;
      transition: opacity .25s, transform .25s;
      z-index: 99; white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.error { background: var(--red); }

    /* ── Site picker sheet ── */
    .sheet-backdrop {
      position: fixed; inset: 0; z-index: 50;
      background: rgba(0,0,0,.35);
      opacity: 0; pointer-events: none;
      transition: opacity .25s;
      -webkit-backdrop-filter: blur(2px);
      backdrop-filter: blur(2px);
    }
    .sheet-backdrop.open { opacity: 1; pointer-events: all; }

    .sheet {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 51;
      background: var(--paper); border-radius: 20px 20px 0 0;
      padding: .5rem 0;
      padding-bottom: max(.5rem, env(safe-area-inset-bottom));
      transform: translateY(100%);
      transition: transform .3s cubic-bezier(.32,0,.67,0);
    }
    .sheet.open { transform: translateY(0); }

    .sheet-handle {
      width: 36px; height: 4px; background: var(--faint);
      border-radius: 2px; margin: .5rem auto 1rem;
    }
    .sheet-title { font-size: .7rem; font-weight: 600; color: var(--ghost); text-transform: uppercase; letter-spacing: .06em; padding: 0 1.25rem .5rem; }

    .sheet-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: .85rem 1.25rem; cursor: pointer;
      font-size: .975rem; font-family: var(--font);
      -webkit-tap-highlight-color: transparent;
      transition: background .1s;
    }
    .sheet-item:active { background: var(--faint); }
    .sheet-item-sub { font-size: .78rem; color: var(--ghost); }
    .sheet-check { color: var(--blue); font-weight: 700; opacity: 0; }
    .sheet-item.selected .sheet-check { opacity: 1; }

    /* ── Spinner ── */
    .spin {
      display: none; width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,.35); border-top-color: #fff;
      border-radius: 50%; animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (min-width: 640px) {
      .surface { padding: 2rem 2rem 0; }
      .body-field { min-height: 400px; }
    }
  </style>
</head>
<body>

<!-- Top nav -->
<nav class="topnav">
  <button class="site-chip" onclick="openSheet()" id="siteChip">
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.5"/></svg>
    <span id="siteChipLabel"><%= activeTitle || activeDomain %></span>
  </button>
  <div class="nav-spacer"></div>
  <button class="nav-btn" onclick="submitDraft()" id="draftBtn">Draft</button>
  <button class="nav-publish" id="publishBtn" onclick="submitPost()">
    <span id="publishLabel">Publish</span>
    <span class="spin" id="publishSpin"></span>
  </button>
</nav>

<% if (flash && flash.success && flash.success.length) { %>
  <script>document.addEventListener('DOMContentLoaded',()=>showToast('<%= flash.success[0].replace(/'/g,"\\'") %>'));</script>
<% } %>
<% if (flash && flash.error && flash.error.length) { %>
  <script>document.addEventListener('DOMContentLoaded',()=>showToast('<%= flash.error[0].replace(/'/g,"\\'") %>',true));</script>
<% } %>

<form id="writeForm" method="POST" action="/write" style="display:contents">
  <input type="hidden" name="domain" id="domainInput" value="<%= activeDomain %>">
  <input type="hidden" name="draft"  id="draftInput"  value="">

  <div class="surface">
    <textarea
      name="title" id="titleInput"
      class="title-field" rows="1"
      placeholder="Title"
      autocorrect="on" autocapitalize="sentences"
      required></textarea>

    <div class="divider"></div>

    <textarea
      name="body" id="bodyInput"
      class="body-field"
      placeholder="Start writing…"
      autocorrect="on" autocapitalize="sentences"
      spellcheck="true"></textarea>
  </div>
</form>

<!-- Bottom bar -->
<div class="bottom-bar">
  <div class="fmt-bar">
    <button class="fmt-btn" onclick="wrap('**','**')" title="Bold"><b>B</b></button>
    <button class="fmt-btn" onclick="wrap('*','*')"   title="Italic"><i>I</i></button>
    <button class="fmt-btn" onclick="heading()"       title="Heading">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><text x="0" y="13" font-size="13" font-weight="700" font-family="Georgia,serif">H</text></svg>
    </button>
    <div class="fmt-sep"></div>
    <button class="fmt-btn" onclick="insertLine('> ')" title="Quote">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4h2v4H3zm6 0h2v4H9zM3 11h2M9 11h2"/></svg>
    </button>
    <button class="fmt-btn" onclick="insertLine('- ')" title="List">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><circle cx="3" cy="5" r="1.5"/><rect x="6" y="4" width="8" height="2" rx="1"/><circle cx="3" cy="11" r="1.5"/><rect x="6" y="10" width="8" height="2" rx="1"/></svg>
    </button>
    <button class="fmt-btn" onclick="insertCode()" title="Code">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 4l-4 4 4 4M11 4l4 4-4 4"/></svg>
    </button>
    <button class="fmt-btn" onclick="insertLink()" title="Link">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 10l4-4M7 6.5H5a2.5 2.5 0 000 5h2M9 9.5h2a2.5 2.5 0 000-5H9"/></svg>
    </button>
    <div class="fmt-sep"></div>
    <label class="fmt-btn" title="Camera">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="4" width="14" height="10" rx="2"/><circle cx="8" cy="9" r="2.5"/><path d="M5 4l1-2h4l1 2"/></svg>
      <input type="file" id="cameraInput" accept="image/*" capture="environment" style="display:none">
    </label>
    <label class="fmt-btn" title="Photo library">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="3" width="14" height="10" rx="2"/><path d="M1 10l3-3 3 3 2-2 3 3"/><circle cx="11" cy="6" r="1.2" fill="currentColor" stroke="none"/></svg>
      <input type="file" id="fileInput" accept="image/*" multiple style="display:none">
    </label>
    <span id="uploadStatus"></span>
  </div>

  <div class="meta-bar">
    <svg class="tag-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1h5l6 6-5 5-6-6V1z"/><circle cx="3.5" cy="3.5" r=".8" fill="currentColor" stroke="none"/></svg>
    <input type="text" name="tags" id="tagsInput" class="tags-field" form="writeForm"
           placeholder="Add tags…" autocomplete="off" autocorrect="off" autocapitalize="none">
    <div class="meta-sep"></div>
    <label class="draft-pill" id="draftPill">
      <input type="checkbox" id="draftCheck">
      <span id="draftPillLabel">Draft</span>
    </label>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- Site picker sheet -->
<div class="sheet-backdrop" id="backdrop" onclick="closeSheet()"></div>
<div class="sheet" id="sheet">
  <div class="sheet-handle"></div>
  <div class="sheet-title">Post to</div>
  <% sites.forEach(s => { %>
    <div class="sheet-item <%= s.domain === activeDomain ? 'selected' : '' %>"
         onclick="selectSite('<%= s.domain %>','<%= s.title.replace(/'/g,"\\'") %>')">
      <div>
        <div><%= s.title %></div>
        <div class="sheet-item-sub"><%= s.domain %></div>
      </div>
      <span class="sheet-check">✓</span>
    </div>
  <% }) %>
</div>

<script>
// ── Auto-resize textareas ──────────────────────────────────────────────────────
function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = el.scrollHeight + 'px';
}
const titleEl = document.getElementById('titleInput');
const bodyEl  = document.getElementById('bodyInput');
titleEl.addEventListener('input', () => autoResize(titleEl));
bodyEl.addEventListener('input',  () => autoResize(bodyEl));

// ── Markdown helpers ───────────────────────────────────────────────────────────
function wrap(b, a) {
  const el = bodyEl; el.focus();
  const s = el.selectionStart, e = el.selectionEnd;
  const sel = el.value.slice(s, e) || 'text';
  el.setRangeText(b + sel + a, s, e, 'end');
  if (!el.value.slice(s,e)) { el.selectionStart = s+b.length; el.selectionEnd = s+b.length+sel.length; }
}
function heading() {
  const el = bodyEl; el.focus();
  const s = el.selectionStart;
  const ls = el.value.lastIndexOf('\n', s-1)+1;
  const cur = el.value.slice(ls, ls+4);
  const p = cur.startsWith('## ') ? '### ' : cur.startsWith('# ') ? '## ' : '# ';
  if (cur.startsWith('#')) el.setRangeText(p, ls, ls+cur.length, 'end');
  else el.setRangeText('# ', ls, ls, 'end');
}
function insertLine(t) {
  const el = bodyEl; el.focus();
  const s = el.selectionStart;
  const needsNewline = s > 0 && el.value[s-1] !== '\n';
  el.setRangeText((needsNewline ? '\n' : '') + t, s, s, 'end');
}
function insertLink() {
  const url = prompt('URL:'); if (!url) return;
  const el = bodyEl; el.focus();
  const s = el.selectionStart, e = el.selectionEnd;
  const sel = el.value.slice(s,e) || 'link text';
  el.setRangeText(`[${sel}](${url})`, s, e, 'end');
}
function insertCode() {
  const el = bodyEl; el.focus();
  const s = el.selectionStart, e = el.selectionEnd;
  const sel = el.value.slice(s,e);
  if (sel.includes('\n') || !sel) el.setRangeText('\n```\n'+(sel||'code')+'\n```\n', s, e, 'end');
  else el.setRangeText('`'+(sel||'code')+'`', s, e, 'end');
}

// ── Image upload ───────────────────────────────────────────────────────────────
const domainVal = document.getElementById('domainInput').value;
const uploadStatus = document.getElementById('uploadStatus');

async function uploadFile(file) {
  const fd = new FormData(); fd.append('images', file);
  const r = await fetch('/media/'+domainVal+'/upload', { method:'POST', body:fd });
  if (!r.ok) throw new Error(await r.text());
  return (await r.json()).files[0].url;
}
async function handleFiles(files) {
  uploadStatus.textContent = '↑';
  for (const f of [...files]) {
    try {
      const url = await uploadFile(f);
      const name = f.name.replace(/\.[^.]+$/,'');
      const s = bodyEl.selectionStart;
      bodyEl.setRangeText('\n!['+name+']('+url+')\n', s, s, 'end');
      autoResize(bodyEl);
      saveDraft();
      uploadStatus.textContent = '✓';
      setTimeout(()=>uploadStatus.textContent='', 2000);
    } catch(e) {
      uploadStatus.textContent = '✗';
      showToast(e.message, true);
    }
  }
}
document.getElementById('cameraInput').addEventListener('change', e => handleFiles(e.target.files));
document.getElementById('fileInput').addEventListener('change',   e => handleFiles(e.target.files));

// ── Draft toggle ───────────────────────────────────────────────────────────────
const draftCheck = document.getElementById('draftCheck');
const draftPill  = document.getElementById('draftPill');
draftCheck.addEventListener('change', () => {
  draftPill.classList.toggle('active', draftCheck.checked);
  document.getElementById('draftInput').value = draftCheck.checked ? '1' : '';
});

// ── Submit ─────────────────────────────────────────────────────────────────────
function submitPost() {
  document.getElementById('draftInput').value = draftCheck.checked ? '1' : '';
  document.getElementById('publishLabel').style.display = 'none';
  document.getElementById('publishSpin').style.display  = 'block';
  clearDraft();
  document.getElementById('writeForm').submit();
}
function submitDraft() {
  document.getElementById('draftInput').value = '1';
  document.getElementById('draftBtn').style.opacity = '.4';
  clearDraft();
  document.getElementById('writeForm').submit();
}

// ── Site picker sheet ──────────────────────────────────────────────────────────
function openSheet() {
  document.getElementById('backdrop').classList.add('open');
  document.getElementById('sheet').classList.add('open');
}
function closeSheet() {
  document.getElementById('backdrop').classList.remove('open');
  document.getElementById('sheet').classList.remove('open');
}
function selectSite(domain, title) {
  closeSheet();
  saveDraft();
  window.location = '/write?site=' + domain;
}

// ── Toast ──────────────────────────────────────────────────────────────────────
function showToast(msg, err) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast' + (err ? ' error' : '');
  requestAnimationFrame(()=>{ t.classList.add('show'); });
  setTimeout(()=>{ t.classList.remove('show'); }, 3000);
}

// ── LocalStorage autosave ──────────────────────────────────────────────────────
const KEY = 'write_' + domainVal;
function saveDraft() {
  localStorage.setItem(KEY, JSON.stringify({
    title: titleEl.value, body: bodyEl.value,
    tags: document.getElementById('tagsInput').value,
    draft: draftCheck.checked,
  }));
}
function clearDraft() { localStorage.removeItem(KEY); }
function restoreDraft() {
  try {
    const d = JSON.parse(localStorage.getItem(KEY));
    if (!d) return;
    if (d.title) { titleEl.value = d.title; autoResize(titleEl); }
    if (d.body)  { bodyEl.value  = d.body;  autoResize(bodyEl);  }
    if (d.tags)  document.getElementById('tagsInput').value = d.tags;
    if (d.draft) { draftCheck.checked = true; draftPill.classList.add('active'); document.getElementById('draftInput').value = '1'; }
  } catch {}
}
restoreDraft();
titleEl.addEventListener('input', saveDraft);
bodyEl.addEventListener('input',  saveDraft);
document.getElementById('tagsInput').addEventListener('input', saveDraft);
</script>
</body>
</html>
