<% pageTitle = 'Claude' %>
<%- include('partials/head') %>

<style>
.claude-layout {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1rem;
  align-items: start;
}
.claude-sidebar {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.claude-repo-select {
  width: 100%;
  padding: .5rem .75rem;
  border: none;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  font-size: .85rem;
  font-weight: 600;
  cursor: pointer;
}
.claude-file-list { list-style: none; margin: 0; padding: .25rem 0; }
.claude-file-list li a {
  display: block;
  padding: .35rem .75rem;
  font-size: .82rem;
  color: var(--text);
  text-decoration: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.claude-file-list li a:hover { background: var(--border); }
.claude-file-list li a.active { background: var(--accent); color: #fff; }
.claude-file-list li a.missing { color: var(--muted); font-style: italic; }
.claude-file-list .file-section {
  padding: .25rem .75rem .1rem;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--muted);
  margin-top: .25rem;
}
.claude-editor {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.claude-editor-header {
  padding: .6rem 1rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: .75rem;
  flex-wrap: wrap;
}
.claude-editor-header code {
  font-size: .82rem;
  flex: 1;
  color: var(--muted);
}
@media (max-width: 640px) {
  .claude-layout { grid-template-columns: 1fr; }
}
</style>

<div class="page-header">
  <h1>Claude</h1>
</div>

<%- include('partials/flash') %>

<div class="claude-layout">
  <!-- Sidebar -->
  <div class="claude-sidebar">
    <select class="claude-repo-select" id="repoSelect" onchange="switchRepo(this.value)">
      <% repos.forEach(r => { %>
      <option value="<%= r.name %>" <%= r.name === repo.name ? 'selected' : '' %>><%= r.name %></option>
      <% }) %>
    </select>

    <ul class="claude-file-list">
      <li class="file-section">Config</li>
      <% files.filter(f => !f.path.startsWith('.claude/commands')).forEach(f => { %>
      <li>
        <a href="/claude?repo=<%= encodeURIComponent(repo.name) %>&file=<%= encodeURIComponent(f.path) %>"
           class="<%= f.path === filePath ? 'active' : '' %> <%= !f.exists ? 'missing' : '' %>">
          <%= f.path %>
        </a>
      </li>
      <% }) %>

      <li class="file-section" style="margin-top:.5rem">Commands</li>
      <% files.filter(f => f.path.startsWith('.claude/commands')).forEach(f => { %>
      <li>
        <% if (f.isNew) { %>
        <a href="/claude?repo=<%= encodeURIComponent(repo.name) %>&new=1" class="<%= isNew ? 'active' : 'missing' %>">
          + new command
        </a>
        <% } else { %>
        <a href="/claude?repo=<%= encodeURIComponent(repo.name) %>&file=<%= encodeURIComponent(f.path) %>"
           class="<%= f.path === filePath ? 'active' : '' %>">
          <%= f.path.replace('.claude/commands/', '') %>
        </a>
        <% } %>
      </li>
      <% }) %>
    </ul>
  </div>

  <!-- Editor -->
  <div class="claude-editor">
    <% if (isNew) { %>
    <!-- New command form -->
    <form method="POST" action="/claude/save">
      <input type="hidden" name="repo" value="<%= repo.name %>">
      <div class="claude-editor-header">
        <span style="font-size:.82rem;color:var(--muted)">.claude/commands/</span>
        <input type="text" name="file" placeholder="command-name.md" required
               style="flex:1;padding:.3rem .5rem;border:1px solid var(--border);border-radius:var(--radius);font-size:.85rem;font-family:var(--mono)"
               oninput="this.value = '.claude/commands/' + this.value.replace(/^\.claude\/commands\//,'')">
        <button class="btn btn-primary btn-sm">Create</button>
      </div>
      <textarea name="content" placeholder="Describe what this command does…"
                style="font-family:var(--mono);font-size:.88rem;min-height:60vh;width:100%;padding:.75rem;border:none;background:var(--surface);color:var(--text);resize:vertical;outline:none"></textarea>
    </form>

    <% } else if (filePath) { %>
    <!-- Edit existing file -->
    <form method="POST" action="/claude/save">
      <input type="hidden" name="repo" value="<%= repo.name %>">
      <input type="hidden" name="file" value="<%= filePath %>">
      <div class="claude-editor-header">
        <code><%= filePath %></code>
        <% if (!fileExists) { %><span style="font-size:.75rem;color:var(--muted)">(new)</span><% } %>
        <button class="btn btn-primary btn-sm">Save</button>
        <% if (fileExists) { %>
        <form method="POST" action="/claude/delete" style="display:inline" onsubmit="return confirm('Delete <%= filePath %>?')">
          <input type="hidden" name="repo" value="<%= repo.name %>">
          <input type="hidden" name="file" value="<%= filePath %>">
          <button class="btn btn-sm btn-danger">Delete</button>
        </form>
        <% } %>
      </div>
      <textarea name="content"
                style="font-family:var(--mono);font-size:.88rem;min-height:70vh;width:100%;padding:.75rem;border:none;background:var(--surface);color:var(--text);resize:vertical;outline:none"><%= content %></textarea>
    </form>

    <% } else { %>
    <div style="padding:3rem;text-align:center;color:var(--muted)">Select a file to edit.</div>
    <% } %>
  </div>
</div>

<script>
function switchRepo(name) {
  window.location = '/claude?repo=' + encodeURIComponent(name);
}
</script>

</main>
</body>
</html>
