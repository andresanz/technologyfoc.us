<% pageTitle = 'Gratitude Prompts' %>
<%- include('partials/head') %>

<div class="page-header">
  <div>
    <h1>Gratitude Prompts</h1>
    <p class="muted" style="margin-top:.25rem;font-size:.875rem"><%= prompts.length %> prompts in rotation. <a href="https://randomcategory.com/gratitude" target="_blank">View entries →</a></p>
  </div>
</div>

<%- include('partials/flash') %>

<form method="POST" action="/gratitude-prompts/add" style="display:flex;gap:.5rem;margin-bottom:1.5rem;">
  <input type="text" name="text" placeholder="Add a new prompt…" required
         style="flex:1;padding:.5rem .75rem;border:1px solid var(--border);border-radius:var(--radius);font-size:.95rem;">
  <button type="submit" class="btn btn-primary">Add</button>
</form>

<div class="post-list-table">
  <% prompts.forEach(function(p, i) { %>
  <div style="display:flex;align-items:center;gap:.75rem;padding:.6rem 0;border-bottom:1px solid var(--border);">
    <span style="flex:1;font-size:.9rem;"><%= p %></span>
    <a href="/gratitude-prompts/edit/<%= i %>" class="btn btn-sm">Edit</a>
    <form method="POST" action="/gratitude-prompts/delete/<%= i %>" style="display:inline"
          onsubmit="return confirm('Delete this prompt?')">
      <button class="btn btn-sm btn-danger">Delete</button>
    </form>
  </div>
  <% }) %>
</div>

</main>
</body>
</html>
