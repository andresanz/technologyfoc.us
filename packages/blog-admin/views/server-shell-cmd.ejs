<%
  pageTitle = 'Shell';
-%>
<%- include('partials/head') %>

<style>
.shell-wrap {
  display: flex; flex-direction: column; gap: 1rem;
}
.terminal {
  background: #1e1e1e; border-radius: var(--radius);
  padding: 1rem; min-height: 200px; max-height: 60vh;
  overflow-y: auto; font-family: var(--mono); font-size: .8rem;
  line-height: 1.6; color: #d4d4d4;
  white-space: pre-wrap; word-break: break-all;
}
.terminal .t-prompt { color: #569cd6; }
.terminal .t-out    { color: #d4d4d4; }
.terminal .t-err    { color: #f44747; }
.terminal .t-ok     { color: #4ec9b0; }

.cmd-row {
  display: flex; gap: .5rem; align-items: stretch;
}
.cmd-input {
  flex: 1; font-family: var(--mono); font-size: 16px;
  background: #1e1e1e; color: #d4d4d4;
  border: 1px solid #3c3c3c; border-radius: var(--radius);
  padding: .6rem .75rem; min-height: 48px;
}
.cmd-input:focus { outline: 2px solid var(--accent); border-color: transparent; }
.cmd-input::placeholder { color: #555; }

.quick-row {
  display: flex; gap: .4rem; flex-wrap: wrap;
}
.quick-row .btn { font-size: .78rem; }

.history-list {
  display: none; flex-direction: column; gap: .2rem;
  background: #2d2d2d; border: 1px solid #3c3c3c;
  border-radius: var(--radius); padding: .5rem;
  max-height: 180px; overflow-y: auto;
}
.history-list.open { display: flex; }
.history-item {
  font-family: var(--mono); font-size: .78rem; color: #9cdcfe;
  cursor: pointer; padding: .2rem .4rem; border-radius: 3px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.history-item:hover { background: #3c3c3c; }

@media (max-width: 640px) {
  .cmd-row { flex-direction: column; }
  .cmd-row .btn { min-height: 48px; }
  .quick-row .btn { flex: 1; min-width: 80px; }
}
</style>

<div class="page-header">
  <div>
    <a href="/server" class="back-link">← Server</a>
    <h1>Shell</h1>
  </div>
</div>

<%- include('partials/flash') %>

<div class="shell-wrap">
  <!-- Quick actions -->
  <div class="quick-row">
    <button class="btn" data-cmd="bash scripts/deploy.sh">⬇ Deploy</button>
    <button class="btn" data-cmd="systemctl restart blog-admin">↺ Restart admin</button>
    <button class="btn" data-cmd="nginx -t">nginx -t</button>
    <button class="btn" data-cmd="systemctl reload nginx">Reload nginx</button>
    <button class="btn" data-cmd="git log --oneline -10">git log</button>
    <button class="btn" data-cmd="systemctl list-timers blog-admin-deploy.timer --no-pager">Timer status</button>
    <button class="btn" data-cmd="systemctl enable --now blog-admin-deploy.timer">Enable timer</button>
  </div>

  <!-- Command input -->
  <div class="cmd-row">
    <input id="cmdInput" class="cmd-input" type="text" placeholder="$ enter command…" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
    <button id="runBtn" class="btn btn-primary" style="min-height:48px;padding:.6rem 1.25rem">Run</button>
    <button id="histBtn" class="btn" title="History" style="min-height:48px">⏱</button>
    <button id="clearBtn" class="btn" title="Clear" style="min-height:48px">✕</button>
  </div>

  <!-- History dropdown -->
  <div id="historyList" class="history-list"></div>

  <!-- Terminal output -->
  <div id="terminal" class="terminal"><span class="t-ok">Ready. Type a command or tap a quick action above.</span>
</div>
</div>

<script>
const terminal  = document.getElementById('terminal');
const cmdInput  = document.getElementById('cmdInput');
const runBtn    = document.getElementById('runBtn');
const clearBtn  = document.getElementById('clearBtn');
const histBtn   = document.getElementById('histBtn');
const histList  = document.getElementById('historyList');

let history = JSON.parse(localStorage.getItem('shell-history') || '[]');
let histIdx = -1;

function saveHistory(cmd) {
  history = [cmd, ...history.filter(h => h !== cmd)].slice(0, 50);
  localStorage.setItem('shell-history', JSON.stringify(history));
  histIdx = -1;
}

function renderHistory() {
  histList.innerHTML = history.map((h, i) =>
    `<div class="history-item" data-i="${i}">${h.replace(/</g,'&lt;')}</div>`
  ).join('');
  histList.querySelectorAll('.history-item').forEach(el => {
    el.addEventListener('click', () => {
      cmdInput.value = history[+el.dataset.i];
      histList.classList.remove('open');
      cmdInput.focus();
    });
  });
}

histBtn.addEventListener('click', () => {
  renderHistory();
  histList.classList.toggle('open');
});

document.addEventListener('click', e => {
  if (!histList.contains(e.target) && e.target !== histBtn) histList.classList.remove('open');
});

cmdInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') { runCommand(cmdInput.value); return; }
  if (e.key === 'ArrowUp') {
    e.preventDefault();
    histIdx = Math.min(histIdx + 1, history.length - 1);
    if (history[histIdx]) cmdInput.value = history[histIdx];
  }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    histIdx = Math.max(histIdx - 1, -1);
    cmdInput.value = histIdx >= 0 ? history[histIdx] : '';
  }
});

runBtn.addEventListener('click', () => runCommand(cmdInput.value));
clearBtn.addEventListener('click', () => { terminal.innerHTML = ''; });

document.querySelectorAll('[data-cmd]').forEach(btn => {
  btn.addEventListener('click', () => {
    cmdInput.value = btn.dataset.cmd;
    runCommand(btn.dataset.cmd);
  });
});

async function runCommand(cmd) {
  cmd = cmd.trim();
  if (!cmd) return;
  saveHistory(cmd);
  histIdx = -1;

  append('t-prompt', '$ ' + cmd);
  runBtn.disabled = true;
  runBtn.textContent = '…';

  try {
    const res = await fetch('/server/shell/run', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cmd }),
    });
    const d = await res.json();
    if (d.output) append(d.code === 0 ? 't-out' : 't-err', d.output);
    else append('t-ok', '(no output, exit ' + d.code + ')');
  } catch (e) {
    append('t-err', 'Request failed: ' + e.message);
  }

  runBtn.disabled = false;
  runBtn.textContent = 'Run';
  cmdInput.value = '';
  cmdInput.focus();
  terminal.scrollTop = terminal.scrollHeight;
}

function append(cls, text) {
  const span = document.createElement('span');
  span.className = cls;
  span.textContent = '\n' + text;
  terminal.appendChild(span);
  terminal.scrollTop = terminal.scrollHeight;
}
</script>

<%- include('partials/foot') %>
